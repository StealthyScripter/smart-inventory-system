<% content_for :page_title, "Reports" %>

<div class="table-container">
  <div class="table-header">
    <h3 class="table-title">User Reports</h3>
  </div>
  <% if @reports.any? %>
    <div class="card-grid">
      <% @reports.each do |report| %>
        <article class="ui-card">
          <div class="card-meta">
            <span class="badge <%= status_badge_class(report.status) %>"><%= report.status.titleize %></span>
            <span><%= report.reportable_type %> #<%= report.reportable_id %></span>
          </div>
          <h3 class="card-title"><%= report.reason %></h3>
          <div class="card-meta">Reporter: <%= report.reporter.full_name %></div>
          <%= form_with model: [:admin, report], method: :patch, local: true, class: "inline-form" do |form| %>
              <%= form.select :status, options_for_select(Report::STATUSES, report.status), {}, { class: "form-select" } %>
              <%= form.submit "Update", class: "btn btn-primary" %>
          <% end %>
        </article>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state"><span class="empty-icon">✓</span><span>No user reports.</span></div>
  <% end %>
</div>
