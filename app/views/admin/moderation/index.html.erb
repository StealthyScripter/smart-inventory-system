<% content_for :page_title, "Marketplace Governance" %>

<div class="table-container">
  <div class="table-header">
    <h3 class="table-title">Open Reports</h3>
  </div>
  <div class="card-grid">
      <% @reports.each do |report| %>
        <article class="ui-card">
          <span class="badge <%= status_badge_class(report.status) %>"><%= report.status.titleize %></span>
          <h3 class="card-title"><%= report.reason %></h3>
          <div class="card-meta">
            <span><%= report.reporter.full_name %></span>
            <span><%= report.reportable_type %> #<%= report.reportable_id %></span>
          </div>
        </article>
      <% end %>
      <% if @reports.empty? %>
        <div class="empty-state"><span class="empty-icon">✓</span><span>No open reports.</span></div>
      <% end %>
  </div>
</div>

<div class="table-container">
  <div class="table-header"><h3 class="table-title">Products</h3></div>
  <div class="card-grid">
      <% @products.each do |product| %>
        <article class="ui-card">
          <span class="badge <%= status_badge_class(product.marketplace_status) %>"><%= product.marketplace_status.titleize %></span>
          <h3 class="card-title"><%= product.name %></h3>
            <%= button_to "Hide", admin_moderation_actions_path,
                          params: { moderation_action: { moderatable_type: "Product", moderatable_id: product.id, action_name: "hide" } },
                          class: "btn btn-secondary" %>
        </article>
      <% end %>
      <% if @products.empty? %>
        <div class="empty-state"><span class="empty-icon">📦</span><span>No products in queue.</span></div>
      <% end %>
  </div>
</div>

<div class="table-container">
  <div class="table-header"><h3 class="table-title">Services</h3></div>
  <div class="card-grid">
      <% @services.each do |service| %>
        <article class="ui-card">
          <span class="badge <%= status_badge_class(service.status) %>"><%= service.status.titleize %></span>
          <h3 class="card-title"><%= service.name %></h3>
            <%= button_to "Hide", admin_moderation_actions_path,
                          params: { moderation_action: { moderatable_type: "ServiceListing", moderatable_id: service.id, action_name: "hide" } },
                          class: "btn btn-secondary" %>
        </article>
      <% end %>
      <% if @services.empty? %>
        <div class="empty-state"><span class="empty-icon">🛠</span><span>No services in queue.</span></div>
      <% end %>
  </div>
</div>

<div class="table-container">
  <div class="table-header"><h3 class="table-title">Reviews</h3></div>
  <div class="card-grid">
      <% @reviews.each do |review| %>
        <article class="ui-card">
          <div class="card-meta">
            <span>★ <%= review.rating %>/5</span>
            <span class="badge <%= status_badge_class(review.status) %>"><%= review.status.titleize %></span>
          </div>
          <p class="clamp-2"><%= review.body %></p>
            <%= button_to "Hide", admin_moderation_actions_path,
                          params: { moderation_action: { moderatable_type: "Review", moderatable_id: review.id, action_name: "hide" } },
                          class: "btn btn-secondary" %>
        </article>
      <% end %>
      <% if @reviews.empty? %>
        <div class="empty-state"><span class="empty-icon">★</span><span>No reviews in queue.</span></div>
      <% end %>
  </div>
</div>

<div class="table-container">
  <div class="table-header"><h3 class="table-title">Merchants</h3></div>
  <div class="card-grid">
      <% @suppliers.each do |supplier| %>
        <article class="ui-card">
          <span class="badge <%= status_badge_class(supplier.shop_status) %>"><%= supplier.shop_status.titleize %></span>
          <h3 class="card-title"><%= supplier.name %></h3>
            <%= button_to "Suspend", admin_moderation_actions_path,
                          params: { moderation_action: { moderatable_type: "Supplier", moderatable_id: supplier.id, action_name: "suspend" } },
                          class: "btn btn-secondary" %>
        </article>
      <% end %>
      <% if @suppliers.empty? %>
        <div class="empty-state"><span class="empty-icon">🏬</span><span>No merchants in queue.</span></div>
      <% end %>
  </div>
</div>

<div class="table-container">
  <div class="table-header"><h3 class="table-title">Moderation Log</h3></div>
  <div class="card-grid">
      <% @moderation_actions.each do |action| %>
        <article class="ui-card">
          <span class="badge badge-secondary"><%= action.action_name.titleize %></span>
          <div class="card-meta">
            <span><%= action.created_at.to_fs(:short) %></span>
            <span><%= action.actor.full_name %></span>
            <span><%= action.moderatable_type %> #<%= action.moderatable_id %></span>
          </div>
        </article>
      <% end %>
      <% if @moderation_actions.empty? %>
        <div class="empty-state"><span class="empty-icon">✓</span><span>No moderation actions yet.</span></div>
      <% end %>
  </div>
</div>
