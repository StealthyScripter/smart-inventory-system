<% variant = local_assigns.fetch(:variant, :standard) %>

<article class="ui-card media-card marketplace-card marketplace-card--service marketplace-card--<%= variant %>">
  <%= link_to service_path(service), class: "marketplace-card__media-link", aria: { label: "View #{service.service_category}" } do %>
    <div class="card-media marketplace-card__media">
      <% if safe_media_url?(service.image_url) %>
        <img src="<%= service.image_url %>" alt="<%= service.service_category %>">
      <% else %>
        <div class="marketplace-card__fallback marketplace-card__fallback--service">
          <%= nav_icon(:services) %>
          <span>Service</span>
        </div>
      <% end %>
    </div>
  <% end %>

  <div class="card-body">
    <div class="price">
      <% if service.starting_price.present? %>
        From <%= currency(service.starting_price.to_f) %>
      <% else %>
        Quote required
      <% end %>
    </div>

    <h3 class="card-title clamp-2"><%= link_to service.service_category, service_path(service) %></h3>

    <% if service.name != service.service_category %>
      <div class="card-meta clamp-2"><%= service.name %></div>
    <% end %>

    <div class="card-meta">
      <span class="meta-item">🏬 <%= link_to service.supplier.name, merchant_storefront_path(service.supplier) %></span>
      <span class="meta-item" aria-label="Rating">★ <%= number_with_precision(service.average_rating, precision: 1) %></span>
    </div>

    <% unless variant == :compact %>
      <div class="card-actions">
        <%= link_to "Schedule", service_path(service), class: "btn btn-primary btn-compact" %>
      </div>
    <% end %>
  </div>
</article>
