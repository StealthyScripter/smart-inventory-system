<% content_for :body_class, "theme-customer" %>
<% content_for :page_title, "Home" %>

<section class="ui-card marketplace-hero">
  <div class="marketplace-hero__copy">
    <span class="badge badge-info">Marketplace</span>
    <h1 class="marketplace-hero__title">Browse goods, services, and merchants in one place.</h1>
    <p class="marketplace-hero__subtitle">
      Discover public listings, revisit recent items, and jump back into shopping without extra steps.
    </p>

    <%= form_with url: search_path, method: :get, local: true, class: "marketplace-search" do |form| %>
      <%= form.search_field :q, value: params[:q], placeholder: "Search goods, services, or merchants", class: "form-input", aria: { label: "Search marketplace" } %>
      <%= form.submit "Search", class: "btn btn-primary" %>
    <% end %>

    <div class="marketplace-quick-links">
      <%= link_to "Shop", catalog_path, class: "btn btn-secondary" %>
      <%= link_to "Services", services_path, class: "btn btn-secondary" %>
      <%= link_to "Merchants", search_path, class: "btn btn-secondary" %>
    </div>
  </div>

  <div class="marketplace-hero__panel">
    <div class="ui-card marketplace-spotlight-card">
      <span class="marketplace-section__eyebrow">Recommended</span>
      <h2 class="marketplace-section__title"><%= pluralize(@recommended_goods.size, "pick") %></h2>
      <p class="marketplace-section__subtitle">Public goods matched from your browsing history or the live marketplace.</p>
    </div>

    <% if @continue_shopping_items.any? %>
      <div class="ui-card marketplace-spotlight-card">
        <span class="marketplace-section__eyebrow">Continue shopping</span>
        <h2 class="marketplace-section__title"><%= pluralize(@continue_shopping_items.size, "item") %></h2>
        <p class="marketplace-section__subtitle">Your active cart is waiting.</p>
        <div class="card-actions">
          <%= link_to "Open cart", cart_path, class: "btn btn-primary" %>
        </div>
      </div>
    <% else %>
      <div class="ui-card marketplace-spotlight-card">
        <span class="marketplace-section__eyebrow">Continue shopping</span>
        <h2 class="marketplace-section__title">No active cart</h2>
        <p class="marketplace-section__subtitle">Start with a few goods or services below.</p>
      </div>
    <% end %>
  </div>
</section>

<section class="marketplace-section">
  <div class="marketplace-section__header">
    <div>
      <div class="marketplace-section__eyebrow">Goods</div>
      <h2 class="marketplace-section__title">Products ready to browse</h2>
    </div>
    <%= link_to "See all goods", catalog_path, class: "btn btn-secondary" %>
  </div>

  <% if @goods.any? %>
    <div class="market-grid">
      <% @goods.each do |product| %>
        <article class="ui-card media-card">
          <div class="card-media">
            <% if product.featured_image.attached? %>
              <%= image_tag product.featured_image, alt: product.name %>
            <% else %>
              <span><%= ui_initial(product.name) %></span>
            <% end %>
          </div>
          <div class="card-body">
            <div class="card-meta">
              <span class="badge <%= status_badge_class(product.marketplace_status) %>"><%= product.marketplace_status.titleize %></span>
              <span class="badge badge-secondary"><%= product.category.name %></span>
            </div>
            <h3 class="card-title clamp-2"><%= link_to product.name, catalog_product_path(product) %></h3>
            <div class="price"><%= currency(product.selling_price.to_f) %></div>
            <div class="card-meta">
              <span class="meta-item">🏬 <%= product.supplier ? link_to(product.supplier.name, merchant_storefront_path(product.supplier)) : "Marketplace" %></span>
            </div>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state"><span class="empty-icon">📦</span><span>No public goods available.</span></div>
  <% end %>
</section>

<section class="marketplace-section">
  <div class="marketplace-section__header">
    <div>
      <div class="marketplace-section__eyebrow">Services</div>
      <h2 class="marketplace-section__title">Bookable services</h2>
    </div>
    <%= link_to "See all services", services_path, class: "btn btn-secondary" %>
  </div>

  <% if @services.any? %>
    <div class="market-grid">
      <% @services.each do |service| %>
        <article class="ui-card media-card">
          <div class="card-media">
            <% if safe_media_url?(service.image_url) %>
              <img src="<%= service.image_url %>" alt="<%= service.name %>">
            <% else %>
              <span><%= ui_initial(service.name) %></span>
            <% end %>
          </div>
          <div class="card-body">
            <div class="card-meta">
              <span class="badge <%= status_badge_class(service.status) %>"><%= service.status.titleize %></span>
              <span class="badge badge-secondary"><%= service.service_category %></span>
            </div>
            <h3 class="card-title clamp-2"><%= link_to service.name, service_path(service) %></h3>
            <div class="price">From <%= currency(service.starting_price.to_f) %></div>
            <div class="card-meta">
              <span class="meta-item">🏬 <%= link_to service.supplier.name, merchant_storefront_path(service.supplier) %></span>
            </div>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state"><span class="empty-icon">🛠</span><span>No public services available.</span></div>
  <% end %>
</section>

<section class="marketplace-section">
  <div class="marketplace-section__header">
    <div>
      <div class="marketplace-section__eyebrow">Merchants</div>
      <h2 class="marketplace-section__title">Shops worth opening</h2>
    </div>
    <%= link_to "See all merchants", search_path, class: "btn btn-secondary" %>
  </div>

  <% if @merchants.any? %>
    <div class="card-grid">
      <% @merchants.each do |merchant| %>
        <article class="ui-card">
          <div class="card-meta">
            <span class="badge badge-secondary">Merchant</span>
            <span>★ <%= number_with_precision(merchant.average_rating, precision: 1) %></span>
          </div>
          <h3 class="card-title"><%= link_to merchant.name, merchant_storefront_path(merchant) %></h3>
          <p class="clamp-2" style="color: var(--muted-text);"><%= merchant.shop_description.presence || "Public merchant storefront" %></p>
        </article>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state"><span class="empty-icon">🏬</span><span>No public merchants available.</span></div>
  <% end %>
</section>

<section class="marketplace-section">
  <div class="marketplace-section__header">
    <div>
      <div class="marketplace-section__eyebrow">Recommended</div>
      <h2 class="marketplace-section__title">Good matches</h2>
    </div>
  </div>

  <% if @recommended_goods.any? %>
    <div class="market-grid">
      <% @recommended_goods.each do |product| %>
        <article class="ui-card media-card">
          <div class="card-media">
            <% if product.featured_image.attached? %>
              <%= image_tag product.featured_image, alt: product.name %>
            <% else %>
              <span><%= ui_initial(product.name) %></span>
            <% end %>
          </div>
          <div class="card-body">
            <div class="card-meta">
              <span class="badge badge-info">Recommended</span>
              <span class="badge badge-secondary"><%= product.category.name %></span>
            </div>
            <h3 class="card-title clamp-2"><%= link_to product.name, catalog_product_path(product) %></h3>
            <div class="price"><%= currency(product.selling_price.to_f) %></div>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state"><span class="empty-icon">★</span><span>No recommendations yet.</span></div>
  <% end %>
</section>

<section class="marketplace-section">
  <div class="marketplace-section__header">
    <div>
      <div class="marketplace-section__eyebrow">Top rated</div>
      <h2 class="marketplace-section__title">Popular picks</h2>
    </div>
  </div>

  <% if @top_rated_goods.any? || @top_rated_merchants.any? %>
    <div class="grid-2">
      <div class="card-grid">
        <% @top_rated_goods.each do |product| %>
          <article class="ui-card">
            <div class="card-meta">
              <span class="badge badge-success">Top rated</span>
              <span>★ <%= number_with_precision(product.average_rating, precision: 1) %></span>
            </div>
            <h3 class="card-title"><%= link_to product.name, catalog_product_path(product) %></h3>
            <div class="card-meta"><span><%= product.category.name %></span></div>
          </article>
        <% end %>
      </div>

      <div class="card-grid">
        <% @top_rated_merchants.each do |merchant| %>
          <article class="ui-card">
            <div class="card-meta">
              <span class="badge badge-success">Top rated</span>
              <span>★ <%= number_with_precision(merchant.average_rating, precision: 1) %></span>
            </div>
            <h3 class="card-title"><%= link_to merchant.name, merchant_storefront_path(merchant) %></h3>
            <p class="clamp-2" style="color: var(--muted-text);"><%= merchant.shop_description.presence || "Top rated storefront" %></p>
          </article>
        <% end %>
      </div>
    </div>
  <% else %>
    <div class="empty-state"><span class="empty-icon">★</span><span>No rating data yet.</span></div>
  <% end %>
</section>

<section class="marketplace-section">
  <div class="marketplace-section__header">
    <div>
      <div class="marketplace-section__eyebrow">Recently added</div>
      <h2 class="marketplace-section__title">Fresh public listings</h2>
    </div>
  </div>

  <% if @recent_items.any? %>
    <div class="market-grid">
      <% @recent_items.each do |item| %>
        <% record = item[:record] %>
        <article class="ui-card media-card">
          <div class="card-body">
            <div class="card-meta">
              <span class="badge badge-secondary"><%= item[:kind].to_s.titleize %></span>
              <% if item[:kind] == :product %>
                <span class="badge badge-info"><%= record.category.name %></span>
              <% else %>
                <span class="badge badge-info"><%= record.service_category %></span>
              <% end %>
            </div>
            <h3 class="card-title clamp-2">
              <% if item[:kind] == :product %>
                <%= link_to record.name, catalog_product_path(record) %>
              <% else %>
                <%= link_to record.name, service_path(record) %>
              <% end %>
            </h3>
            <div class="card-meta">
              <% if item[:kind] == :product %>
                <span><%= currency(record.selling_price.to_f) %></span>
                <span><%= record.supplier.name %></span>
              <% else %>
                <span>From <%= currency(record.starting_price.to_f) %></span>
                <span><%= record.supplier.name %></span>
              <% end %>
            </div>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state"><span class="empty-icon">⌕</span><span>No recent listings yet.</span></div>
  <% end %>
</section>
