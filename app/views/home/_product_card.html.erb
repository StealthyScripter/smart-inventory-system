<% variant = local_assigns.fetch(:variant, :standard) %>
<% listing = product.marketplace_listing %>
<% sale_price = listing&.sale_price %>
<% public_title = listing&.title.presence || product.name %>

<article class="ui-card media-card marketplace-card marketplace-card--product marketplace-card--<%= variant %>">
  <%= link_to catalog_product_path(product), class: "marketplace-card__media-link", aria: { label: "View #{public_title}" } do %>
    <div class="card-media marketplace-card__media">
      <% if product.featured_image.attached? %>
        <%= image_tag product.featured_image, alt: public_title %>
      <% else %>
        <div class="marketplace-card__fallback marketplace-card__fallback--product">
          <%= nav_icon(:products) %>
          <span>Product</span>
        </div>
      <% end %>
    </div>
  <% end %>

  <div class="card-body">
    <div class="price">
      <% if sale_price.present? %>
        <span class="price-sale"><%= currency(sale_price.to_f) %></span>
        <span class="price-compare"><%= currency(listing.public_price.to_f) %></span>
      <% else %>
        <%= currency((listing&.current_price || product.selling_price).to_f) %>
      <% end %>
    </div>

    <h3 class="card-title clamp-2"><%= link_to public_title, catalog_product_path(product) %></h3>

    <div class="card-meta">
      <span class="meta-item">🏬 <%= product.supplier ? link_to(product.supplier.name, merchant_storefront_path(product.supplier)) : "Marketplace" %></span>
    </div>

    <% unless variant == :compact %>
      <div class="card-actions">
        <%= link_to "View product", catalog_product_path(product), class: "btn btn-secondary btn-compact" %>
      </div>
    <% end %>
  </div>
</article>
