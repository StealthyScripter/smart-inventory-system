<% content_for :page_title, "Notifications" %>

<div class="table-container">
  <div class="table-header">
    <h3 class="table-title">Notifications</h3>
  </div>
  <% if @notifications.any? %>
    <div class="card-grid">
      <% @notifications.each do |notification| %>
        <article class="ui-card">
          <div class="card-meta">
            <span class="badge <%= notification.read_at? ? "badge-success" : "badge-info" %>"><%= notification.read_at? ? "Read" : "Unread" %></span>
            <span>📅 <%= notification.created_at.strftime("%b %d, %Y %H:%M") %></span>
          </div>
          <h3 class="card-title"><%= notification.title %></h3>
          <p class="card-copy clamp-2"><%= notification.body %></p>
          <div class="card-actions">
            <% unless notification.read_at? %>
              <%= button_to "Mark Read", notification_path(notification), method: :patch, class: "btn btn-secondary" %>
            <% end %>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state"><span class="empty-icon">🔔</span><span>No notifications.</span></div>
  <% end %>
</div>
