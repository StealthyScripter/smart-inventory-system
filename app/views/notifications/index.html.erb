<% content_for :page_title, "Notifications" %>

<section class="page-section">
  <div class="section-header">
    <div>
      <h2 class="section-title">Notifications</h2>
      <p class="section-subtitle">Updates about orders, bookings, messages, and account activity.</p>
    </div>
  </div>

  <% if @notifications.any? %>
    <div class="card-grid">
      <% @notifications.each do |notification| %>
        <article class="ui-card notification-card">
          <div class="card-body">
            <div class="card-kicker"><%= notification.event_type.to_s.tr(".", " ").titleize %></div>
            <h3 class="card-title"><%= notification.title %></h3>
            <p><%= notification.body %></p>
            <div class="order-card-meta">
              <%= render "shared/status_badge", status: notification.read_at? ? "read" : "pending", label: notification.read_at? ? "Read" : "Unread" %>
              <span class="muted-text"><%= notification.created_at.strftime("%b %d, %Y %H:%M") %></span>
            </div>
          </div>
          <% unless notification.read_at? %>
            <div class="card-actions">
              <%= button_to "Mark Read", notification_path(notification), method: :patch, class: "btn btn-secondary" %>
            </div>
          <% end %>
        </article>
      <% end %>
    </div>
  <% else %>
    <%= render "shared/empty_state", title: "No notifications", message: "New activity will appear here." %>
  <% end %>
</section>
