<% content_for :page_title, "Locations" %>

<section class="merchant-page enterprise-management-page">
  <header class="merchant-page-header">
    <div>
      <span class="merchant-page-kicker">Enterprise operations</span>
      <h1>Locations</h1>
      <p>Stock coverage, managers, and operating sites.</p>
    </div>
    <% if can_manage_locations? %>
      <%= link_to "Add Location", new_location_path, class: "btn btn-primary" %>
    <% else %>
      <span class="badge badge-secondary">Read Only</span>
    <% end %>
  </header>

  <div class="card-grid enterprise-location-grid">
    <% @locations.each do |location| %>
      <article class="ui-card enterprise-location-card">
        <div class="profile-card-head">
          <%= nav_icon(:locations) %>
          <h2 class="card-title"><%= link_to location.name, location_path(location) %></h2>
        </div>
        <div class="card-meta">
          <span>📍 <%= location.address.presence || "Address not set" %></span>
          <span>👤 <%= location.manager&.full_name || "Unassigned" %></span>
        </div>
        <div class="summary-row"><span>Units on hand</span><strong><%= number_with_delimiter(location.stock_levels.sum(:current_quantity)) %></strong></div>
        <div class="card-actions">
          <% if can_manage_locations? %>
            <%= link_to "Edit", edit_location_path(location), class: "btn btn-secondary btn-compact" %>
          <% else %>
            <%= link_to "View", location_path(location), class: "btn btn-secondary btn-compact" %>
          <% end %>
        </div>
      </article>
    <% end %>
  </div>
</section>
