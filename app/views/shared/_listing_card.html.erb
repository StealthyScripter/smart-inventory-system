<% product = listing.product %>
<% merchant = product&.supplier %>
<% review_count = product&.reviews&.published&.count.to_i %>

<article class="ui-card media-card listing-card marketplace-card">
  <%= link_to catalog_product_path(product), class: "card-media-link", aria: { label: "View #{listing.title}" } do %>
    <% if listing.featured_media_url.present? %>
      <img class="card-media" src="<%= listing.featured_media_url %>" alt="<%= listing.title %>">
    <% elsif product&.featured_image&.attached? %>
      <%= image_tag product.featured_image, class: "card-media", alt: listing.title %>
    <% else %>
      <div class="card-media placeholder-media" role="img" aria-label="<%= listing.title %> image placeholder">
        <span><%= listing.title.to_s.first&.upcase || "P" %></span>
      </div>
    <% end %>
  <% end %>

  <div class="card-body">
    <div class="price-row">
      <% if listing.sale_price.present? %>
        <span class="price"><%= currency(listing.sale_price) %></span>
        <span class="list-price"><%= currency(listing.public_price) %></span>
      <% else %>
        <span class="price"><%= currency(listing.current_price.to_f) %></span>
      <% end %>
    </div>
    <h3 class="card-title clamp-2"><%= link_to listing.title, catalog_product_path(product) %></h3>
    <div class="card-meta">
      <span><%= merchant ? link_to(merchant.name, merchant_storefront_path(merchant)) : "Marketplace" %></span>
      <span aria-label="Rating">★ <%= number_with_precision(product&.average_rating.to_f, precision: 1) %> (<%= review_count %>)</span>
    </div>
    <div class="card-meta">
      <%= render "shared/status_badge", status: listing.availability, label: listing.availability.humanize %>
      <span><%= product&.category&.name || "Marketplace" %></span>
    </div>
  </div>

  <div class="card-actions">
    <%= link_to "View", catalog_product_path(product), class: "btn btn-secondary btn-compact" %>
    <% if current_user&.customer? %>
      <%= button_to "Add to cart", cart_path(product_id: product.id, quantity: 1), method: :post, class: "btn btn-primary btn-compact" %>
    <% end %>
  </div>
</article>
