<% badge_status = local_assigns.fetch(:status).to_s %>
<% badge_label = local_assigns[:label].presence || badge_status.humanize %>
<% badge_class = case badge_status
                 when "active", "available", "paid", "delivered", "completed", "public"
                   "badge-success"
                 when "pending", "confirmed", "scheduled", "preorder", "processing"
                   "badge-warning"
                 when "hidden", "archived", "failed", "cancelled", "suspended", "out_of_stock", "unavailable"
                   "badge-danger"
                 else
                   "badge-secondary"
                 end %>
<span class="badge <%= badge_class %>"><%= badge_label %></span>
