<% review_count = service.reviews.published.count %>

<article class="ui-card media-card listing-card service-card marketplace-card">
  <%= link_to service_path(service), class: "card-media-link", aria: { label: "View #{service.name}" } do %>
    <% if service.image_url.present? %>
      <img class="card-media" src="<%= service.image_url %>" alt="<%= service.name %>">
    <% elsif service.gallery_images.attached? %>
      <%= image_tag service.gallery_images.first, class: "card-media", alt: service.name %>
    <% else %>
      <div class="card-media placeholder-media" role="img" aria-label="<%= service.name %> image placeholder">
        <span><%= service.name.to_s.first&.upcase || "S" %></span>
      </div>
    <% end %>
  <% end %>

  <div class="card-body">
    <div class="price-row">
      <span class="price"><%= service.starting_price.present? ? currency(service.starting_price.to_f) : "Quote required" %></span>
    </div>
    <h3 class="card-title"><%= link_to service.service_category, service_path(service) %></h3>
    <% if service.name != service.service_category %>
      <p class="card-meta clamp-2"><%= service.name %></p>
    <% end %>
    <div class="card-meta">
      <span><%= link_to service.supplier.name, merchant_storefront_path(service.supplier) %></span>
      <span aria-label="Rating">★ <%= number_with_precision(service.average_rating, precision: 1) %> (<%= review_count %>)</span>
      <%= render "shared/status_badge", status: service.status, label: service.status.humanize %>
    </div>
  </div>

  <div class="card-actions">
    <%= link_to "View", service_path(service), class: "btn btn-secondary btn-compact" %>
    <% if current_user&.customer? %>
      <%= link_to "Schedule", service_path(service, anchor: "booking"), class: "btn btn-primary btn-compact" %>
    <% end %>
  </div>
</article>
