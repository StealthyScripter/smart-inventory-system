<% content_for :page_title, "Marketplace Search" %>

<div class="table-container">
  <div class="table-header">
    <h3 class="table-title">Search Marketplace</h3>
  </div>

  <div class="filter-bar">
    <%= form_with url: search_path, method: :get, local: true, class: "filter-grid" do |form| %>
      <div class="form-group" style="margin-bottom: 0;">
        <%= form.label :service_category, "Service", class: "form-label" %>
        <%= form.select :service_category, options_for_select(@service_categories, params[:service_category]),
                        { include_blank: "All services" }, { class: "form-select" } %>
      </div>
      <div class="form-group" style="margin-bottom: 0;">
        <%= form.label :merchant_id, "Merchant", class: "form-label" %>
        <%= form.select :merchant_id, options_from_collection_for_select(@merchant_options, :id, :name, params[:merchant_id]),
                        { include_blank: "All merchants" }, { class: "form-select" } %>
      </div>
      <div class="form-group" style="margin-bottom: 0;">
        <%= form.label :sort, "Sort", class: "form-label" %>
        <%= form.select :sort,
                        options_for_select([["Name", ""], ["Price: Low to High", "price_asc"], ["Price: High to Low", "price_desc"], ["Highest Rated", "rating"], ["Newest", "newest"]], params[:sort]),
                        {}, { class: "form-select" } %>
      </div>
      <%= form.submit "Search", class: "btn btn-primary" %>
    <% end %>
  </div>

  <% if @suggestions.any? %>
    <div class="card-meta" style="padding: 1rem 1.5rem; border-top: 1px solid var(--border-color);">
      <strong>Try:</strong>
      <%= @suggestions.join(", ") %>
    </div>
  <% end %>
</div>

<div class="table-container">
  <div class="table-header"><h3 class="table-title">Products</h3></div>
  <% if @products.any? %>
    <div class="market-grid">
      <% @products.each do |product| %>
        <article class="ui-card media-card">
          <div class="card-media">
            <% if product.featured_image.attached? %>
              <%= image_tag product.featured_image, alt: product.name %>
            <% else %>
              <span><%= ui_initial(product.name) %></span>
            <% end %>
          </div>
          <div class="card-body">
            <h3 class="card-title clamp-2"><%= link_to product.name, catalog_product_path(product) %></h3>
            <div class="price"><%= currency(product.selling_price.to_f) %></div>
            <div class="card-meta">
              <span>🏷 <%= product.category.name %></span>
              <span>★ <%= number_with_precision(product.average_rating, precision: 1) %></span>
            </div>
            <div class="card-meta">🏬 <%= product.supplier ? link_to(product.supplier.name, merchant_storefront_path(product.supplier)) : "Marketplace" %></div>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state"><span class="empty-icon">⌕</span><span>No products found.</span></div>
  <% end %>
  <%= pagination_controls(@products) %>
</div>

<div class="table-container">
  <div class="table-header"><h3 class="table-title">Services</h3></div>
  <% if @services.any? %>
    <div class="market-grid">
      <% @services.each do |service| %>
        <article class="ui-card media-card">
          <div class="card-media">
            <% if safe_media_url?(service.image_url) %>
              <img src="<%= service.image_url %>" alt="<%= service.name %>">
            <% else %>
              <span><%= ui_initial(service.name) %></span>
            <% end %>
          </div>
          <div class="card-body">
            <h3 class="card-title clamp-2"><%= link_to service.name, service_path(service) %></h3>
            <div class="price">From <%= currency(service.starting_price.to_f) %></div>
            <div class="card-meta">
              <span>🛠 <%= service.service_category %></span>
              <span>★ <%= number_with_precision(service.average_rating, precision: 1) %></span>
            </div>
            <div class="card-meta">🏬 <%= link_to service.supplier.name, merchant_storefront_path(service.supplier) %></div>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state"><span class="empty-icon">🛠</span><span>No services found.</span></div>
  <% end %>
</div>

<div class="table-container">
  <div class="table-header"><h3 class="table-title">Merchants</h3></div>
  <% if @merchants.any? %>
    <div class="card-grid">
      <% @merchants.each do |merchant| %>
        <article class="ui-card">
          <h3 class="card-title"><%= link_to merchant.name, merchant_storefront_path(merchant) %></h3>
          <p class="clamp-2" style="color: var(--muted-text);"><%= merchant.shop_description.presence || "Marketplace seller" %></p>
          <div class="card-meta">★ <%= number_with_precision(merchant.average_rating, precision: 1) %></div>
        </article>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state"><span class="empty-icon">🏬</span><span>No merchants found.</span></div>
  <% end %>
</div>

<div class="table-container">
  <div class="table-header"><h3 class="table-title">Categories</h3></div>
  <table>
    <tbody>
      <% @categories.each do |category| %>
        <tr>
          <td><%= link_to category.name, catalog_path(category_id: category.id, q: params[:q]) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
