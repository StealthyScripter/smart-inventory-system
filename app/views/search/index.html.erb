<% content_for :page_title, "Marketplace Search" %>

<div class="table-container">
  <div class="table-header">
    <h3 class="table-title">Search Marketplace</h3>
  </div>

  <div class="filter-bar">
    <%= form_with url: search_path, method: :get, local: true, class: "filter-grid" do |form| %>
      <div class="form-group" style="margin-bottom: 0;">
        <%= form.label :service_category, "Service", class: "form-label" %>
        <%= form.select :service_category, options_for_select(@service_categories, params[:service_category]),
                        { include_blank: "All services" }, { class: "form-select" } %>
      </div>
      <div class="form-group" style="margin-bottom: 0;">
        <%= form.label :merchant_id, "Merchant", class: "form-label" %>
        <%= form.select :merchant_id, options_from_collection_for_select(@merchant_options, :id, :name, params[:merchant_id]),
                        { include_blank: "All merchants" }, { class: "form-select" } %>
      </div>
      <div class="form-group" style="margin-bottom: 0;">
        <%= form.label :sort, "Sort", class: "form-label" %>
        <%= form.select :sort,
                        options_for_select([["Name", ""], ["Price: Low to High", "price_asc"], ["Price: High to Low", "price_desc"], ["Highest Rated", "rating"], ["Newest", "newest"]], params[:sort]),
                        {}, { class: "form-select" } %>
      </div>
      <%= form.submit "Search", class: "btn btn-primary" %>
    <% end %>
  </div>

  <% if @suggestions.any? %>
    <div class="card-meta" style="padding: 1rem 1.5rem; border-top: 1px solid var(--border-color);">
      <strong>Try:</strong>
      <%= @suggestions.join(", ") %>
    </div>
  <% end %>
</div>

<div class="table-container">
  <div class="table-header"><h3 class="table-title">Products</h3></div>
  <% if @products.any? %>
    <div class="market-grid">
      <% @products.each do |product| %>
        <%= render "home/product_card", product: product, variant: :standard %>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state"><span class="empty-icon">⌕</span><span>No products found.</span></div>
  <% end %>
  <%= pagination_controls(@products) %>
</div>

<div class="table-container">
  <div class="table-header"><h3 class="table-title">Services</h3></div>
  <% if @services.any? %>
    <div class="market-grid">
      <% @services.each do |service| %>
        <%= render "home/service_card", service: service, variant: :standard %>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state"><span class="empty-icon">🛠</span><span>No services found.</span></div>
  <% end %>
</div>

<div class="table-container">
  <div class="table-header"><h3 class="table-title">Merchants</h3></div>
  <% if @merchants.any? %>
    <div class="card-grid">
      <% @merchants.each do |merchant| %>
        <%= render "home/merchant_card", merchant: merchant, variant: :standard %>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state"><span class="empty-icon">🏬</span><span>No merchants found.</span></div>
  <% end %>
</div>

<div class="table-container">
  <div class="table-header"><h3 class="table-title">Categories</h3></div>
  <div class="category-grid">
    <% @categories.each do |category| %>
      <%= link_to category.name, catalog_path(category_id: category.id, q: params[:q]), class: "category-chip" %>
    <% end %>
  </div>
</div>
