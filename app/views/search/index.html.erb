<% content_for :page_title, "Marketplace Search" %>
<% content_for :breadcrumbs do %>
  Marketplace / Search
<% end %>

<section class="page-section">
  <div class="section-header">
    <div>
      <h2 class="section-title">Marketplace Search</h2>
      <p class="section-subtitle">Search products, services, merchants, and categories.</p>
    </div>
  </div>

  <div class="filter-card">
    <%= form_with url: search_path, method: :get, local: true, class: "filter-grid" do |form| %>
      <div class="form-group" style="margin-bottom: 0;">
        <%= form.label :q, "Search", class: "form-label" %>
        <%= form.text_field :q, value: params[:q], class: "form-input", placeholder: "What are you looking for?" %>
      </div>
      <div class="form-group" style="margin-bottom: 0;">
        <%= form.label :service_category, "Service", class: "form-label" %>
        <%= form.select :service_category, options_for_select(@service_categories, params[:service_category]),
                        { include_blank: "All services" }, { class: "form-select" } %>
      </div>
      <div class="form-group" style="margin-bottom: 0;">
        <%= form.label :merchant_id, "Merchant", class: "form-label" %>
        <%= form.select :merchant_id, options_from_collection_for_select(@merchant_options, :id, :name, params[:merchant_id]),
                        { include_blank: "All merchants" }, { class: "form-select" } %>
      </div>
      <div class="form-group" style="margin-bottom: 0;">
        <%= form.label :sort, "Sort", class: "form-label" %>
        <%= form.select :sort,
                        options_for_select([["Name", ""], ["Price: Low to High", "price_asc"], ["Price: High to Low", "price_desc"], ["Highest Rated", "rating"], ["Newest", "newest"]], params[:sort]),
                        {}, { class: "form-select" } %>
      </div>
      <%= form.submit "Search", class: "btn btn-primary" %>
    <% end %>
    <% if @suggestions.any? %>
      <p class="muted-text" style="margin-top: 1rem;"><strong>Suggestions:</strong> <%= @suggestions.join(", ") %></p>
    <% end %>
  </div>
</section>

<section class="page-section">
  <div class="section-header"><h2 class="section-title">Products</h2></div>
  <% product_listings = @products.filter_map(&:marketplace_listing) %>
  <% if product_listings.any? %>
    <div class="card-grid">
      <%= render partial: "shared/listing_card", collection: product_listings, as: :listing %>
    </div>
    <%= pagination_controls(@products) %>
  <% else %>
    <%= render "shared/empty_state", title: "No matching products" %>
  <% end %>
</section>

<section class="page-section">
  <div class="section-header"><h2 class="section-title">Services</h2></div>
  <% if @services.any? %>
    <div class="card-grid">
      <%= render partial: "shared/service_card", collection: @services, as: :service %>
    </div>
  <% else %>
    <%= render "shared/empty_state", title: "No matching services" %>
  <% end %>
</section>

<section class="page-section">
  <div class="section-header"><h2 class="section-title">Merchants</h2></div>
  <% if @merchants.any? %>
    <div class="card-grid compact">
      <%= render partial: "shared/merchant_card", collection: @merchants, as: :merchant %>
    </div>
  <% else %>
    <%= render "shared/empty_state", title: "No matching merchants" %>
  <% end %>
</section>

<section class="page-section">
  <div class="section-header"><h2 class="section-title">Categories</h2></div>
  <% if @categories.any? %>
    <div class="card-grid compact">
      <% @categories.each do |category| %>
        <article class="ui-card">
          <div class="card-body">
            <h3 class="card-title"><%= link_to category.name, catalog_path(category_id: category.id, q: params[:q]) %></h3>
            <p class="card-meta"><%= category.description.presence || "Marketplace category" %></p>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <%= render "shared/empty_state", title: "No matching categories" %>
  <% end %>
</section>
