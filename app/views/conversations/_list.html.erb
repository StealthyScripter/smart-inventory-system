<div class="table-container">
  <div class="table-header"><h3 class="table-title">Conversations</h3></div>
  <% if conversations.any? %>
    <div class="card-grid">
      <% conversations.each do |conversation| %>
        <article class="ui-card">
          <div class="card-meta">
            <span>🏬 <%= conversation.supplier.name %></span>
            <span>📅 <%= conversation.updated_at.strftime("%b %d, %Y %H:%M") %></span>
          </div>
          <h3 class="card-title"><%= link_to conversation.subject, conversation_path(conversation) %></h3>
          <span class="badge <%= conversation.messages.where.not(sender: current_user).unread.count.positive? ? "badge-info" : "badge-secondary" %>">
            💬 <%= conversation.messages.where.not(sender: current_user).unread.count %>
          </span>
        </article>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state"><span class="empty-icon">💬</span><span>No conversations yet.</span></div>
  <% end %>
</div>
