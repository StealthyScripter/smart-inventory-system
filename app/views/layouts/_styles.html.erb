<style>
  :root {
    --space-1: 0.25rem;
    --space-2: 0.5rem;
    --space-3: 0.75rem;
    --space-4: 1rem;
    --space-5: 1.25rem;
    --space-6: 1.5rem;
    --space-8: 2rem;
    --radius-sm: 0.375rem;
    --radius-md: 0.625rem;
    --radius-lg: 0.875rem;
    --shadow-sm: 0 1px 2px rgba(15, 23, 42, 0.06);
    --shadow-md: 0 12px 28px rgba(15, 23, 42, 0.08);
    --shadow-focus: 0 0 0 3px rgba(37, 99, 235, 0.18);
    --page-bg: #f6f8fb;
    --card-bg: #ffffff;
    --border-color: #dbe3ef;
    --text-color: #172033;
    --muted-text: #64748b;
    --success: #15803d;
    --success-bg: #dcfce7;
    --warning: #a16207;
    --warning-bg: #fef3c7;
    --danger: #b91c1c;
    --danger-bg: #fee2e2;
    --info: #0369a1;
    --info-bg: #e0f2fe;
    --accent: #2563eb;
    --accent-strong: #1d4ed8;
    --accent-soft: #dbeafe;
    --topbar-bg: rgba(255, 255, 255, 0.92);
    --topbar-border: rgba(148, 163, 184, 0.18);
    --sidebar-bg: #182235;
    --sidebar-border: rgba(255, 255, 255, 0.1);
    --content-max: 1440px;
    --bottom-nav-height: 4.5rem;
  }

  body.theme-guest {
    --accent: #475569;
    --accent-strong: #334155;
    --accent-soft: #e2e8f0;
    --sidebar-bg: #1f2937;
  }

  body.theme-customer {
    --accent: #0f766e;
    --accent-strong: #115e59;
    --accent-soft: #ccfbf1;
    --topbar-bg: rgba(236, 253, 245, 0.94);
    --sidebar-bg: #12312e;
  }

  body.theme-merchant,
  body.theme-individual-merchant {
    --accent: #7c3aed;
    --accent-strong: #6d28d9;
    --accent-soft: #ede9fe;
    --topbar-bg: rgba(250, 245, 255, 0.94);
    --sidebar-bg: #24183d;
  }

  body.theme-enterprise,
  body.theme-enterprise-merchant {
    --accent: #1d4ed8;
    --accent-strong: #1e40af;
    --accent-soft: #dbeafe;
    --topbar-bg: rgba(239, 246, 255, 0.94);
    --sidebar-bg: #111827;
  }

  body.theme-operator {
    --accent: #334155;
    --accent-strong: #1f2937;
    --accent-soft: #e2e8f0;
    --sidebar-bg: #0f172a;
  }

  * {
    min-width: 0;
  }

  html {
    overflow-x: hidden;
  }

  body {
    font-family: "Roboto", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background: var(--page-bg);
    color: var(--text-color);
    line-height: 1.5;
    overflow-x: hidden;
    text-rendering: optimizeLegibility;
  }

  a {
    color: var(--accent);
    text-decoration: none;
    overflow-wrap: anywhere;
  }

  a:hover {
    color: var(--accent-strong);
  }

  img {
    max-width: 100%;
    height: auto;
  }

  :focus-visible {
    outline: none;
    box-shadow: var(--shadow-focus);
  }

  .app-container {
    background:
      radial-gradient(circle at top right, color-mix(in srgb, var(--accent-soft) 58%, transparent), transparent 28rem),
      var(--page-bg);
  }

  .app-shell {
    display: flex;
    min-height: 100vh;
    min-width: 0;
  }

  .app-shell--account {
    flex-direction: column;
  }

  .app-shell__body {
    display: flex;
    flex: 1 1 auto;
    min-width: 0;
  }

  .sidebar {
    background: var(--sidebar-bg);
    border-right: 1px solid var(--sidebar-border);
    flex: 0 0 280px;
    min-height: 100vh;
    position: sticky;
    top: 0;
    scrollbar-width: thin;
  }

  .logo {
    padding: var(--space-5) var(--space-6);
    border-bottom-color: var(--sidebar-border);
  }

  .logo h1 {
    color: #fff;
    font-size: 1.15rem;
    line-height: 1.2;
  }

  .nav-menu {
    padding: var(--space-2);
  }

  .nav-link {
    border-radius: var(--radius-md);
    color: #d8e1ee;
    gap: var(--space-3);
    margin: var(--space-1) 0;
    padding: 0.72rem 1rem;
  }

  .nav-link:hover,
  .nav-link.active {
    background: rgba(255, 255, 255, 0.1);
    color: #fff;
  }

  .nav-link.active {
    box-shadow: inset 3px 0 0 var(--accent);
  }

  .nav-icon {
    flex: 0 0 20px;
    margin-right: 0;
  }

  .main-content {
    flex: 1 1 auto;
    max-width: calc(100vw - 280px);
  }

  .app-main {
    min-width: 0;
  }

  .app-main--account {
    flex: 1 1 auto;
  }

  .account-content {
    padding-bottom: calc(var(--space-8) + var(--bottom-nav-height) + env(safe-area-inset-bottom));
  }

  .topbar {
    align-items: center;
    background: var(--topbar-bg);
    border-bottom: 1px solid var(--topbar-border);
    display: flex;
    gap: var(--space-4);
    justify-content: space-between;
    padding: var(--space-4) clamp(var(--space-4), 3vw, var(--space-8));
    position: sticky;
    top: 0;
    z-index: 12;
    backdrop-filter: blur(14px);
  }

  .topbar-brand {
    align-items: center;
    display: flex;
    flex: 1 1 280px;
    gap: var(--space-3);
    min-width: 0;
  }

  .brand-link {
    align-items: center;
    color: var(--text-color);
    display: inline-flex;
    gap: var(--space-2);
    font-weight: 800;
    white-space: nowrap;
  }

  .brand-mark {
    align-items: center;
    background: var(--accent);
    border-radius: 0.45rem;
    color: #fff;
    display: inline-flex;
    font-size: 0.72rem;
    height: 1.6rem;
    justify-content: center;
    width: 1.6rem;
  }

  .brand-name {
    font-size: 0.98rem;
  }

  .topbar-title {
    color: var(--muted-text);
    font-size: 0.95rem;
    font-weight: 700;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .top-search {
    flex: 1 1 420px;
    max-width: 560px;
    min-width: min(240px, 100%);
  }

  .top-search__input {
    min-height: 3rem;
    width: 100%;
  }

  .topbar-actions {
    align-items: center;
    display: flex;
    gap: var(--space-2);
  }

  .topbar-action {
    align-items: center;
    background: #fff;
    border: 1px solid var(--border-color);
    border-radius: 999px;
    color: var(--text-color);
    display: inline-flex;
    gap: var(--space-2);
    min-height: 3rem;
    padding: 0.55rem 0.9rem;
  }

  .topbar-action:hover {
    border-color: var(--accent);
    color: var(--accent-strong);
  }

  .topbar-action svg {
    width: 1rem;
    height: 1rem;
  }

  .account-bottom-nav {
    background: rgba(255, 255, 255, 0.98);
    border-top: 1px solid var(--border-color);
    bottom: 0;
    box-shadow: 0 -10px 24px rgba(15, 23, 42, 0.08);
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(0, 1fr));
    gap: 0;
    left: 0;
    padding-bottom: env(safe-area-inset-bottom);
    position: fixed;
    width: 100%;
    z-index: 15;
  }

  .account-bottom-nav__link {
    align-items: center;
    border-top: 3px solid transparent;
    color: var(--muted-text);
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    justify-content: center;
    min-height: var(--bottom-nav-height);
    padding: 0.55rem 0.35rem;
  }

  .account-bottom-nav__link:hover,
  .account-bottom-nav__link.is-active {
    background: color-mix(in srgb, var(--accent-soft) 55%, #fff);
    border-top-color: var(--accent);
    color: var(--accent-strong);
  }

  .account-bottom-nav__link svg {
    width: 1.1rem;
    height: 1.1rem;
  }

  .account-bottom-nav__label {
    font-size: 0.76rem;
    font-weight: 700;
    line-height: 1;
  }

  .sidebar--admin {
    background: var(--sidebar-bg);
    border-right: 1px solid var(--sidebar-border);
    flex: 0 0 240px;
    min-height: 100vh;
    padding: 0;
    position: sticky;
    top: 0;
  }

  .sidebar-subtitle {
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.82rem;
    margin-top: 0.25rem;
  }

  .sidebar-nav {
    display: grid;
    gap: var(--space-2);
    padding: var(--space-2);
  }

  .sidebar-link {
    align-items: center;
    border-radius: var(--radius-md);
    color: #d8e1ee;
    display: flex;
    gap: var(--space-3);
    padding: 0.8rem 1rem;
  }

  .sidebar-link:hover,
  .sidebar-link.is-active {
    background: rgba(255, 255, 255, 0.1);
    color: #fff;
  }

  .sidebar-link.is-active {
    box-shadow: inset 3px 0 0 var(--accent);
  }

  .profile-hero {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-5);
    justify-content: space-between;
    margin-bottom: var(--space-5);
  }

  .profile-hero-copy {
    flex: 1 1 340px;
    min-width: 0;
  }

  .profile-name {
    color: var(--text-color);
    font-size: clamp(1.5rem, 2.5vw, 2.25rem);
    line-height: 1.1;
    margin-top: var(--space-3);
  }

  .profile-subtitle {
    color: var(--muted-text);
    margin-top: var(--space-2);
  }

  .profile-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-4);
  }

  .profile-meta-item {
    align-items: center;
    background: #f8fafc;
    border: 1px solid var(--border-color);
    border-radius: 999px;
    color: var(--muted-text);
    display: inline-flex;
    gap: 0.35rem;
    padding: 0.42rem 0.8rem;
  }

  .profile-hero-actions {
    align-items: flex-start;
    display: flex;
    flex: 0 1 18rem;
    flex-wrap: wrap;
    gap: var(--space-2);
    justify-content: flex-end;
  }

  .profile-grid {
    display: grid;
    gap: var(--space-5);
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 220px), 1fr));
    margin-bottom: var(--space-5);
  }

  .profile-grid--primary {
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 260px), 1fr));
  }

  .profile-feature-card,
  .profile-link-card {
    gap: var(--space-3);
    justify-content: space-between;
    min-height: 11rem;
  }

  .profile-feature-card--accent {
    border-left: 4px solid var(--accent);
  }

  .profile-card-kicker {
    color: var(--muted-text);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .profile-card-head {
    align-items: center;
    display: flex;
    gap: var(--space-3);
  }

  .profile-card-copy {
    color: var(--muted-text);
    line-height: 1.45;
  }

  .profile-card-footer {
    align-items: center;
    display: flex;
    justify-content: space-between;
    gap: var(--space-3);
    margin-top: auto;
  }

  .profile-card-action {
    color: var(--accent-strong);
    font-size: 0.9rem;
    font-weight: 700;
  }

  .marketplace-hero {
    display: grid;
    gap: var(--space-5);
    grid-template-columns: minmax(0, 1.25fr) minmax(280px, 0.75fr);
    margin-bottom: var(--space-6);
  }

  .marketplace-hero__copy {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .marketplace-hero__title {
    color: var(--text-color);
    font-size: clamp(1.65rem, 2.8vw, 2.4rem);
    line-height: 1.1;
  }

  .marketplace-hero__subtitle {
    color: var(--muted-text);
    max-width: 56rem;
  }

  .marketplace-search {
    display: grid;
    gap: var(--space-3);
    grid-template-columns: minmax(0, 1fr) auto;
    margin-top: var(--space-2);
  }

  .marketplace-search .form-input {
    min-height: 3.1rem;
  }

  .marketplace-quick-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-2);
  }

  .marketplace-hero__panel {
    display: grid;
    gap: var(--space-3);
  }

  .marketplace-section {
    margin-bottom: var(--space-6);
  }

  .marketplace-section__header {
    align-items: end;
    display: flex;
    justify-content: space-between;
    gap: var(--space-3);
    margin-bottom: var(--space-3);
  }

  .marketplace-section__eyebrow {
    color: var(--muted-text);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .marketplace-section__title {
    color: var(--text-color);
    font-size: 1.05rem;
    font-weight: 750;
  }

  .marketplace-section__subtitle {
    color: var(--muted-text);
    font-size: 0.9rem;
  }

  .marketplace-home-shell {
    display: grid;
    gap: var(--space-5);
  }

  .marketplace-home-header {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    align-items: center;
    display: grid;
    gap: var(--space-3);
    grid-template-columns: auto minmax(0, 1.3fr) auto auto;
    padding: var(--space-3) var(--space-4);
  }

  .marketplace-home-brand {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    min-width: 0;
  }

  .marketplace-home-brand__link {
    border: 1px solid transparent;
    padding: 0;
  }

  .marketplace-home-brand__tag {
    background: var(--accent-soft);
    border-radius: 999px;
    color: var(--accent-strong);
    font-size: 0.68rem;
    font-weight: 750;
    letter-spacing: 0.03em;
    padding: 0.22rem 0.55rem;
    text-transform: uppercase;
  }

  .marketplace-home-search {
    align-items: center;
    display: grid;
    gap: var(--space-2);
    grid-template-columns: minmax(0, 1fr) auto;
    min-width: 0;
  }

  .marketplace-home-search__input {
    min-height: 3rem;
  }

  .marketplace-home-search__submit,
  .marketplace-home-cart {
    min-width: 0;
  }

  .marketplace-home-actions {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    justify-content: flex-end;
  }

  .marketplace-home-account {
    align-items: flex-start;
    background: color-mix(in srgb, var(--card-bg) 92%, var(--accent-soft));
    border: 1px solid color-mix(in srgb, var(--border-color) 75%, var(--accent-soft));
    border-radius: var(--radius-md);
    color: var(--text-color);
    display: inline-flex;
    flex-direction: column;
    gap: 0.05rem;
    min-height: 2.9rem;
    padding: 0.35rem 0.7rem;
  }

  .marketplace-home-account:hover {
    border-color: var(--accent);
    color: var(--accent-strong);
  }

  .marketplace-home-account__eyebrow {
    color: var(--muted-text);
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .marketplace-home-account__label {
    font-size: 0.9rem;
    font-weight: 750;
    line-height: 1.2;
  }

  .marketplace-home-cart {
    gap: var(--space-2);
    min-height: 2.9rem;
    padding: 0.35rem 0.75rem;
  }

  .marketplace-home-cart svg {
    width: 1.05rem;
    height: 1.05rem;
  }

  .marketplace-home-cart__label {
    font-size: 0.9rem;
    font-weight: 700;
  }

  .marketplace-home-search__submit {
    align-items: center;
    display: inline-flex;
    gap: var(--space-2);
    min-height: 3rem;
    padding: 0.55rem 0.95rem;
  }

  .marketplace-home-search__submit svg {
    width: 1rem;
    height: 1rem;
  }

  .marketplace-menu {
    overflow: hidden;
    padding: var(--space-3) var(--space-4);
  }

  .marketplace-menu__track {
    display: flex;
    gap: var(--space-2);
    overflow-x: auto;
    padding-bottom: var(--space-2);
    scroll-snap-type: x mandatory;
  }

  .marketplace-menu__track::-webkit-scrollbar {
    display: none;
  }

  .marketplace-menu__link {
    align-items: center;
    background: color-mix(in srgb, var(--card-bg) 90%, var(--accent-soft));
    border: 1px solid var(--border-color);
    border-radius: 999px;
    color: var(--text-color);
    display: inline-flex;
    flex: 0 0 auto;
    font-size: 0.8rem;
    font-weight: 750;
    min-height: 2.25rem;
    padding: 0.3rem 0.75rem;
    scroll-snap-align: start;
    white-space: nowrap;
  }

  .marketplace-menu__link:hover {
    border-color: var(--accent);
    color: var(--accent-strong);
  }

  .marketplace-home-hero {
    display: grid;
    gap: var(--space-4);
    grid-template-columns: minmax(0, 1.05fr) minmax(300px, 0.95fr);
    padding: var(--space-4);
  }

  .marketplace-home-hero__copy {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    justify-content: center;
    min-width: 0;
  }

  .marketplace-home-hero__title {
    color: var(--text-color);
    font-size: clamp(1.65rem, 2.6vw, 2.4rem);
    line-height: 1.05;
  }

  .marketplace-home-hero__subtitle {
    color: var(--muted-text);
    font-size: 0.98rem;
    max-width: 36rem;
  }

  .marketplace-home-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .marketplace-home-hero__chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .marketplace-home-chip {
    align-items: center;
    background: color-mix(in srgb, var(--card-bg) 88%, var(--accent-soft));
    border: 1px solid var(--border-color);
    border-radius: 999px;
    color: var(--text-color);
    display: inline-flex;
    font-size: 0.76rem;
    font-weight: 750;
    min-height: 2rem;
    padding: 0.22rem 0.65rem;
  }

  .marketplace-home-hero__visual {
    display: grid;
    gap: var(--space-3);
    min-width: 0;
  }

  .marketplace-home-promo {
    display: grid;
    gap: var(--space-3);
    grid-template-columns: minmax(180px, 0.95fr) minmax(0, 1.05fr);
    min-height: 100%;
    padding: var(--space-4);
  }

  .marketplace-home-promo__media {
    border-radius: var(--radius-md);
    overflow: hidden;
    min-height: 14rem;
  }

  .marketplace-home-promo__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .marketplace-home-promo__fallback {
    align-items: center;
    background: linear-gradient(135deg, var(--accent-soft), #fff);
    display: flex;
    height: 100%;
    justify-content: center;
  }

  .marketplace-home-promo__fallback svg {
    color: var(--accent);
    height: 3rem;
    width: 3rem;
  }

  .marketplace-home-promo__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    justify-content: center;
    min-width: 0;
  }

  .marketplace-home-promo__eyebrow {
    color: var(--muted-text);
    font-size: 0.72rem;
    font-weight: 750;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .marketplace-home-promo__title {
    font-size: 1.05rem;
    line-height: 1.25;
  }

  .marketplace-home-promo__copy {
    color: var(--muted-text);
    font-size: 0.9rem;
  }

  .marketplace-home-promo__stats {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .marketplace-card {
    min-width: 0;
  }

  .marketplace-card__media {
    aspect-ratio: 1 / 1;
  }

  .marketplace-card--feature .marketplace-card__media {
    aspect-ratio: 4 / 3;
    min-height: 14rem;
  }

  .marketplace-card--compact .card-body {
    gap: var(--space-2);
    padding: var(--space-3);
  }

  .marketplace-card--compact .marketplace-card__media {
    aspect-ratio: 4 / 3;
  }

  .marketplace-card--merchant .marketplace-merchant-card__media {
    aspect-ratio: 16 / 9;
    background: linear-gradient(135deg, var(--accent-soft), #fff);
    overflow: hidden;
  }

  .marketplace-card--merchant .marketplace-merchant-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .marketplace-card__fallback {
    align-items: center;
    color: var(--accent);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    justify-content: center;
    height: 100%;
    padding: var(--space-3);
    width: 100%;
  }

  .marketplace-card__fallback svg {
    height: 1.75rem;
    width: 1.75rem;
  }

  .marketplace-card__fallback span {
    color: var(--muted-text);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.03em;
