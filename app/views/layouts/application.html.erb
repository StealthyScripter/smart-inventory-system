<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Smart Inventory System" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%= render partial: "layouts/styles" %>
  </head>

  <body class="<%= content_for?(:body_class) ? yield(:body_class) : account_theme_class %>">
    <% if logged_in? %>
      <% if account_navigation? %>
        <div class="app-shell app-shell--account">
          <header class="topbar topbar--account">
            <div class="topbar-brand">
              <%= link_to root_path, class: "brand-link" do %>
                <span class="brand-mark">◼</span>
                <span class="brand-name">Smart Inventory</span>
              <% end %>
              <span class="topbar-title"><%= yield(:page_title).presence || "Dashboard" %></span>
            </div>

            <% unless customer_navigation? && current_page?(root_path) %>
              <%= form_with url: search_path, method: :get, local: true, class: "top-search" do |form| %>
                <%= form.search_field :q, value: params[:q], placeholder: "Search marketplace", class: "form-input top-search__input", aria: { label: "Search marketplace" } %>
              <% end %>
            <% end %>

            <div class="topbar-actions">
              <% if customer_navigation? %>
                <%= link_to cart_path, class: "topbar-action topbar-action--cart", aria: { label: "Cart" } do %>
                  <%= nav_icon(:cart) %>
                  <span>Cart</span>
                <% end %>
              <% end %>
            </div>
          </header>

          <main class="app-main app-main--account">
            <div class="content-area account-content">
              <% flash.each do |type, message| %>
                <div class="alert flash-<%= type %>"><%= message %></div>
              <% end %>
              <%= yield %>
            </div>
          </main>
        </div>

        <%= render "layouts/account_bottom_nav" %>
      <% else %>
        <div class="app-shell app-shell--admin">
          <%= render "layouts/admin_sidebar" %>

          <div class="app-shell__body">
            <header class="topbar topbar--admin">
              <div class="topbar-brand">
                <%= link_to root_path, class: "brand-link" do %>
                  <span class="brand-mark">◼</span>
                  <span class="brand-name">Smart Inventory</span>
                <% end %>
                <span class="topbar-title"><%= yield(:page_title).presence || "Dashboard" %></span>
              </div>

              <%= form_with url: search_path, method: :get, local: true, class: "top-search" do |form| %>
                <%= form.search_field :q, value: params[:q], placeholder: "Search marketplace", class: "form-input top-search__input", aria: { label: "Search marketplace" } %>
              <% end %>
            </header>

            <main class="app-main">
              <div class="content-area account-content">
                <% flash.each do |type, message| %>
                  <div class="alert flash-<%= type %>"><%= message %></div>
                <% end %>
                <%= yield %>
              </div>
            </main>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="content-area public-shell">
        <% flash.each do |type, message| %>
          <div class="alert flash-<%= type %>"><%= message %></div>
        <% end %>
        <%= yield %>
      </div>
    <% end %>
  </body>
</html>
