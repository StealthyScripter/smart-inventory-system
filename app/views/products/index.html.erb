<% content_for :page_title, "Products" %>

<div class="table-container">
  <div class="table-header">
    <h3 class="table-title">Product Catalog</h3>
    <% if can_manage_products? %>
      <%= link_to "Add Product", new_product_path, class: "btn btn-primary" %>
    <% else %>
      <span class="badge badge-secondary">Read Only</span>
    <% end %>
  </div>
  <table>
    <thead>
      <tr>
        <th>SKU</th>
        <th>Name</th>
        <th>Category</th>
        <th>Supplier</th>
        <th>Unit Cost</th>
        <th>Selling Price</th>
        <th>Stock</th>
        <th>Reorder Point</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @products.each do |product| %>
        <tr>
          <td><%= product.sku %></td>
          <td><%= link_to product.name, product_path(product) %></td>
          <td><%= product.category.name %></td>
          <td><%= product.supplier&.name || "Unassigned" %></td>
          <td><%= currency(product.unit_cost.to_f) %></td>
          <td><%= currency(product.selling_price.to_f) %></td>
          <td class="<%= product.total_stock < product.reorder_point ? 'stock-low' : 'stock-ok' %>">
            <%= number_with_delimiter(product.total_stock) %>
          </td>
          <td><%= product.reorder_point %></td>
          <td>
            <% if can_manage_products? %>
              <%= link_to "Edit", edit_product_path(product), class: "btn btn-secondary", style: "padding: 0.25rem 0.5rem; font-size: 0.875rem;" %>
            <% else %>
              <span style="color: #718096; font-size: 0.875rem;">View</span>
            <% end %>
          </td>
        </tr>
      <% end %>
      <% if @products.empty? %>
        <tr>
          <td colspan="9" style="text-align: center; color: #718096; font-style: italic;">
            No products found.
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
