<% content_for :page_title, "Cart" %>

<% cart_items = @cart.cart_items.includes(product: :marketplace_listing) %>
<% cart_total = cart_items.sum do |item|
     listing = item.product.marketplace_listing
     unit_price = listing&.current_price || item.product.selling_price.to_d
     unit_price.to_d * item.quantity
   end %>

<div class="table-container">
  <div class="table-header">
    <h3 class="table-title">Your Cart</h3>
    <%= link_to "Continue Shopping", catalog_path, class: "btn btn-secondary" %>
  </div>

  <% if cart_items.empty? %>
    <div class="empty-state">
      Your cart is empty.
      <div style="margin-top: 1rem;">
        <%= link_to "Browse Catalog", catalog_path, class: "btn btn-primary" %>
      </div>
    </div>
  <% else %>
    <table>
      <thead>
        <tr>
          <th>Listing</th>
          <th>Unit Price</th>
          <th>Quantity</th>
          <th>Subtotal</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% cart_items.each do |item| %>
          <% listing = item.product.marketplace_listing %>
          <% listing_title = listing&.title.presence || item.product.name %>
          <% unit_price = listing&.current_price || item.product.selling_price.to_d %>
          <% subtotal = unit_price.to_d * item.quantity %>
          <tr>
            <td>
              <strong><%= link_to listing_title, catalog_product_path(item.product) %></strong>
              <% if listing&.availability.present? %>
                <div style="color: #718096; margin-top: 0.25rem;"><%= listing.availability.humanize %></div>
              <% end %>
            </td>
            <td><%= currency(unit_price) %></td>
            <td>
              <%= form_with url: cart_path, method: :patch, local: true, style: "display: flex; gap: 0.5rem;" do |form| %>
                <%= form.hidden_field :item_id, value: item.id %>
                <%= form.number_field :quantity, value: item.quantity, min: 1, class: "form-input", style: "width: 6rem;" %>
                <%= form.submit "Update", class: "btn btn-secondary" %>
              <% end %>
            </td>
            <td><%= currency(subtotal) %></td>
            <td>
              <%= button_to "Remove", cart_path(item_id: item.id), method: :delete, class: "btn btn-danger" %>
            </td>
          </tr>
        <% end %>
      </tbody>
      <tfoot>
        <tr>
          <td colspan="3"><strong>Total</strong></td>
          <td><strong><%= currency(cart_total) %></strong></td>
          <td></td>
        </tr>
      </tfoot>
    </table>

    <div style="padding: 1.5rem; display: flex; gap: 0.75rem; justify-content: flex-end; flex-wrap: wrap;">
      <%= link_to "Continue Shopping", catalog_path, class: "btn btn-secondary" %>
      <%= link_to "Review Checkout", checkout_path, class: "btn btn-primary" %>
    </div>
  <% end %>
</div>
