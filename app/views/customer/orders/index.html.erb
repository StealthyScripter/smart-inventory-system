<% content_for :page_title, "My Orders" %>

<section class="page-section">
  <div class="section-header">
    <div>
      <h2 class="section-title">Orders</h2>
      <p class="section-subtitle">Track purchases and review delivered items.</p>
    </div>
  </div>

  <% if @orders.any? %>
    <div class="card-grid">
      <% @orders.each do |order| %>
        <%= render "shared/order_card", order: order, path: customer_order_path(order) %>
      <% end %>
    </div>
  <% else %>
    <%= render "shared/empty_state",
               title: "No orders found",
               message: "Your purchases will appear here after checkout.",
               action: "Browse Catalog",
               path: catalog_path %>
  <% end %>
</section>
