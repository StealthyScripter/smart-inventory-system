<% content_for :page_title, "My Orders" %>

<div class="table-container">
  <div class="table-header">
    <h3 class="table-title">Orders</h3>
  </div>
  <table>
    <thead>
      <tr>
        <th>Order</th>
        <th>Status</th>
        <th>Total</th>
        <th>Submitted</th>
      </tr>
    </thead>
    <tbody>
      <% @orders.each do |order| %>
        <tr>
          <td><%= link_to order.order_number, customer_order_path(order) %></td>
          <td><span class="badge badge-secondary"><%= order.status.titleize %></span></td>
          <td><%= currency(order.total_amount.to_f) %></td>
          <td><%= order.submitted_at&.strftime("%b %d, %Y") || order.created_at.strftime("%b %d, %Y") %></td>
        </tr>
      <% end %>
      <% if @orders.empty? %>
        <tr><td colspan="4" style="text-align: center; color: #718096; font-style: italic;">No orders found.</td></tr>
      <% end %>
    </tbody>
  </table>
</div>
