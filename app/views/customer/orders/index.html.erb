<% content_for :page_title, "My Orders" %>

<div class="table-container">
  <div class="table-header">
    <h3 class="table-title">Orders</h3>
  </div>
  <% if @orders.any? %>
    <div class="card-grid">
      <% @orders.each do |order| %>
        <%= render "shared/order_card", order: order, path: customer_order_path(order) %>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state"><span class="empty-icon">📦</span><span>No orders found.</span></div>
  <% end %>
</div>
