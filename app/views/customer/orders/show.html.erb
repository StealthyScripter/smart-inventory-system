<% content_for :page_title, @order.order_number %>
<% content_for :breadcrumbs do %>
  Customer / Orders / <%= @order.order_number %>
<% end %>

<section class="page-section">
  <div class="section-header">
    <div>
      <h2 class="section-title">Order <%= @order.order_number %></h2>
      <p class="section-subtitle">Tracking, fulfillment, and review details.</p>
    </div>
    <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
      <%= link_to "PDF Receipt", customer_order_path(@order, format: :pdf), class: "btn btn-secondary" %>
      <%= link_to "Back to Orders", customer_orders_path, class: "btn btn-secondary" %>
    </div>
  </div>

  <div class="dashboard-card-grid">
    <%= render "shared/metric_card", label: "Status", value: @order.status.titleize %>
    <%= render "shared/metric_card", label: "Total", value: currency(@order.total_amount.to_f) %>
    <%= render "shared/metric_card", label: "Submitted", value: (@order.submitted_at&.to_date || @order.created_at.to_date) %>
  </div>
</section>

<section class="page-section">
  <div class="section-header">
    <h2 class="section-title">Items</h2>
  </div>
  <% if @order.order_items.any? %>
    <div class="card-grid">
      <% @order.order_items.each do |item| %>
        <article class="ui-card">
          <div class="card-body">
            <div class="card-kicker"><%= item.supplier.name %></div>
            <h3 class="card-title"><%= item.product.marketplace_listing&.title.presence || item.product.name %></h3>
            <div class="summary-row">
              <span>Quantity</span>
              <strong><%= item.quantity %></strong>
            </div>
            <div class="summary-row">
              <span>Fulfillment</span>
              <%= render "shared/status_badge", status: item.fulfillment_status, label: item.fulfillment_status.titleize %>
            </div>
            <div class="summary-row">
              <span>Tracking</span>
              <strong><%= item.tracking_number.present? ? [item.tracking_carrier, item.tracking_number].compact.join(" ") : "Not available" %></strong>
            </div>
          </div>
          <% if item.fulfillment_status == "delivered" && item.reviews.where(user: current_user).empty? %>
            <div class="card-actions">
              <%= form_with url: reviews_path, method: :post, local: true, style: "display: grid; gap: 0.5rem; width: 100%;" do |form| %>
                <%= hidden_field_tag :order_item_id, item.id %>
                <%= hidden_field_tag :order_id, @order.id %>
                <%= form.fields_for :review do |review_form| %>
                  <%= review_form.number_field :rating, min: 1, max: 5, value: 5, class: "form-input", aria: { label: "Rating" } %>
                  <%= review_form.text_field :body, class: "form-input", placeholder: "Review" %>
                  <%= review_form.file_field :photos, multiple: true, accept: "image/*", class: "form-input" %>
                <% end %>
                <%= form.submit "Submit Review", class: "btn btn-secondary" %>
              <% end %>
            </div>
          <% end %>
        </article>
      <% end %>
    </div>
  <% else %>
    <%= render "shared/empty_state", title: "No order items", message: "No order items are attached to this order." %>
  <% end %>
</section>
