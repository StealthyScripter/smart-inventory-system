<% content_for :page_title, "Profile" %>
<% content_for :breadcrumbs do %>
  Customer / Profile
<% end %>

<section class="page-section">
  <div class="section-header">
    <div>
      <h2 class="section-title"><%= current_user.full_name %></h2>
      <p class="section-subtitle"><%= current_user.email %></p>
    </div>
  </div>

  <div class="profile-action-grid primary">
    <%= link_to customer_orders_path, class: "profile-action-card prominent" do %>
      <span class="card-kicker">Orders</span>
      <strong>Orders</strong>
      <span><%= pluralize(@orders_count, "order") %></span>
    <% end %>

    <%= link_to customer_service_bookings_path, class: "profile-action-card prominent" do %>
      <span class="card-kicker">Bookings</span>
      <strong>Bookings</strong>
      <span><%= pluralize(@bookings_count, "booking") %></span>
    <% end %>
  </div>

  <div class="profile-action-grid">
    <%= link_to "Edit profile", signup_path, class: "profile-action-card" %>
    <%= link_to "Manage lists", catalog_path, class: "profile-action-card" %>
    <%= link_to "Previous orders", customer_orders_path, class: "profile-action-card" %>
    <%= link_to "Inbox", customer_conversations_path, class: "profile-action-card" %>
    <%= link_to "Notifications (#{@unread_notifications_count})", notifications_path, class: "profile-action-card" %>
    <%= button_to "Sign out", logout_path, method: :delete, class: "profile-action-card button-card" %>
  </div>
</section>
