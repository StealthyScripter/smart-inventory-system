<% content_for :page_title, "Profile" %>

<section class="customer-profile" aria-labelledby="customer-profile-name">
  <header class="customer-profile__header">
    <div class="customer-profile__avatar" role="img" aria-label="<%= current_user.full_name %> avatar">
      <span><%= current_user.first_name.to_s.first %><%= current_user.last_name.to_s.first %></span>
    </div>
    <h1 id="customer-profile-name" class="customer-profile__name"><%= current_user.full_name %></h1>
  </header>

  <nav class="customer-profile__primary-actions" aria-label="Orders and bookings">
    <%= link_to customer_orders_path, class: "customer-profile__primary-action" do %>
      <%= nav_icon(:orders) %>
      <span>Orders</span>
      <strong><%= @orders_count %></strong>
    <% end %>

    <%= link_to customer_service_bookings_path, class: "customer-profile__primary-action" do %>
      <%= nav_icon(:bookings) %>
      <span>Bookings</span>
      <strong><%= @bookings_count %></strong>
    <% end %>
  </nav>

  <div class="customer-profile__list" role="list" aria-label="Profile options">
    <%= link_to customer_profile_path, class: "customer-profile__row", role: "listitem" do %>
      <span class="customer-profile__row-icon"><%= nav_icon(:profile) %></span>
      <span class="customer-profile__row-label">Edit profile</span>
      <span class="customer-profile__chevron" aria-hidden="true">›</span>
    <% end %>

    <%= link_to catalog_path, class: "customer-profile__row", role: "listitem" do %>
      <span class="customer-profile__row-icon"><%= nav_icon(:catalog) %></span>
      <span class="customer-profile__row-label">My lists</span>
      <span class="customer-profile__chevron" aria-hidden="true">›</span>
    <% end %>

    <%= link_to customer_conversations_path, class: "customer-profile__row", role: "listitem" do %>
      <span class="customer-profile__row-icon"><%= nav_icon(:inbox) %></span>
      <span class="customer-profile__row-label">Inbox</span>
      <span class="customer-profile__row-meta"><%= @conversations.size %></span>
      <span class="customer-profile__chevron" aria-hidden="true">›</span>
    <% end %>

    <%= link_to notifications_path, class: "customer-profile__row", role: "listitem" do %>
      <span class="customer-profile__row-icon"><%= nav_icon(:notifications) %></span>
      <span class="customer-profile__row-label">Notifications</span>
      <span class="customer-profile__row-meta"><%= @unread_notifications_count %></span>
      <span class="customer-profile__chevron" aria-hidden="true">›</span>
    <% end %>

    <%= link_to customer_profile_path, class: "customer-profile__row", role: "listitem" do %>
      <span class="customer-profile__row-icon"><%= nav_icon(:settings) %></span>
      <span class="customer-profile__row-label">Settings</span>
      <span class="customer-profile__chevron" aria-hidden="true">›</span>
    <% end %>

    <div class="customer-profile__row is-disabled" role="listitem" aria-disabled="true">
      <span class="customer-profile__row-icon"><%= nav_icon(:help) %></span>
      <span class="customer-profile__row-label">Help</span>
    </div>

    <div class="customer-profile__row is-disabled" role="listitem" aria-disabled="true">
      <span class="customer-profile__row-icon"><%= nav_icon(:contact) %></span>
      <span class="customer-profile__row-label">Contact us</span>
    </div>

    <div class="customer-profile__signout" role="listitem">
      <%= button_to logout_path,
                    method: :delete,
                    form: { data: { turbo_confirm: "Are you sure you want to sign out?" } },
                    class: "customer-profile__row customer-profile__row--signout" do %>
        <span class="customer-profile__row-icon"><%= nav_icon(:signout) %></span>
        <span class="customer-profile__row-label">Sign out</span>
      <% end %>
    </div>
  </div>
</section>
