<% content_for :page_title, "Service Bookings" %>

<div class="table-container">
  <div class="table-header"><h3 class="table-title">Bookings</h3></div>
  <% if @bookings.any? %>
    <div class="card-grid">
      <% @bookings.each do |booking| %>
        <%= render "shared/booking_card",
                   booking: booking,
                   cancel_path: (customer_service_booking_path(booking) if ServiceBooking::TRANSITIONS.fetch(booking.status).include?("cancelled")) %>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state"><span class="empty-icon">📅</span><span>No service bookings yet.</span></div>
  <% end %>
</div>
