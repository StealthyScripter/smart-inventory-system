<% content_for :page_title, "Service Bookings" %>
<% content_for :breadcrumbs do %>
  Customer / Bookings
<% end %>

<div class="table-container">
  <div class="table-header"><h3 class="table-title">Bookings</h3></div>
  <table>
    <thead>
      <tr><th>Booking</th><th>Service</th><th>Provider</th><th>Status</th><th>Schedule</th><th>Actions</th></tr>
    </thead>
    <tbody>
      <% @bookings.each do |booking| %>
        <tr>
          <td><%= booking.booking_number %></td>
          <td><%= booking.service_listings.map(&:name).to_sentence %></td>
          <td><%= booking.supplier.name %></td>
          <td><%= booking.status.titleize %></td>
          <td><%= [booking.scheduled_date, booking.scheduled_time&.strftime("%H:%M")].compact.join(" ") %></td>
          <td>
            <% if ServiceBooking::TRANSITIONS.fetch(booking.status).include?("cancelled") %>
              <%= button_to "Cancel", customer_service_booking_path(booking), method: :patch, class: "btn btn-danger" %>
            <% end %>
          </td>
        </tr>
      <% end %>
      <% if @bookings.empty? %>
        <tr><td colspan="6" class="empty-state">No service bookings yet.</td></tr>
      <% end %>
    </tbody>
  </table>
</div>
