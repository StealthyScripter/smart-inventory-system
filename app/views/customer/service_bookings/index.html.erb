<% content_for :page_title, "Service Bookings" %>

<div class="table-container">
  <div class="table-header"><h3 class="table-title">Bookings</h3></div>
  <% if @bookings.any? %>
    <div class="card-grid">
      <% @bookings.each do |booking| %>
        <article class="ui-card">
          <div class="card-meta">
            <span class="badge <%= status_badge_class(booking.status) %>"><%= booking.status.titleize %></span>
            <span>📅 <%= [booking.scheduled_date, booking.scheduled_time&.strftime("%H:%M")].compact.join(" ") %></span>
          </div>
          <h3 class="card-title"><%= booking.booking_number %></h3>
          <div class="card-meta">
            <span>🛠 <%= booking.service_listings.map(&:name).to_sentence %></span>
            <span>🏬 <%= booking.supplier.name %></span>
          </div>
          <div class="card-actions">
            <% if ServiceBooking::TRANSITIONS.fetch(booking.status).include?("cancelled") %>
              <%= button_to "Cancel", customer_service_booking_path(booking), method: :patch, class: "btn btn-danger" %>
            <% end %>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state"><span class="empty-icon">📅</span><span>No service bookings yet.</span></div>
  <% end %>
</div>
