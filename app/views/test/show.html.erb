<div class="max-w-3xl mx-auto mt-10 bg-white border border-gray-300 rounded-md shadow-sm">
  <div class="px-6 py-4 border-b border-gray-300">
    <h2 class="text-2xl font-semibold">Profile</h2>
  </div>

  <div class="px-6 py-6">
    <div class="flex items-center gap-6 mb-6">
      Profile Picture

      <div>
        <p class="text-lg font-medium">Demo user</p>
        <p class="text-sm text-gray-600">demo@inventory.com</p>
      </div>
    </div>

    <table class="w-full text-sm">
      <tbody>
        <tr class="border-t">
          <th class="py-2 pr-4 text-left text-gray-700 font-medium">Age</th>
          <td class="py-2">26</td>
        </tr>

        <tr class="border-t">
          <th class="py-2 pr-4 text-left text-gray-700 font-medium">Gender</th>
          <td class="py-2">Male</td>
        </tr>

        <tr class="border-t">
          <th class="py-2 pr-4 text-left text-gray-700 font-medium">Location</th>
          <td class="py-2">Demo City, Demo State, 12345</td>
        </tr>

        <tr class="border-t">
          <th class="py-2 pr-4 text-left text-gray-700 font-medium">Bio</th>
          <td class="py-2">Demo bio content here.</td>
        </tr>

        <tr class="border-t">
          <th class="py-2 pr-4 text-left text-gray-700 font-medium">Roles</th>
          <td class="py-2">Admin</td>
        </tr>
      </tbody>
    </table>

    <div class="mt-6 border-t pt-4">
      link_to "Edit Profile", edit_user_path(current_user), class: "inline-block px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700"
    </div>
  </div>
</div>
