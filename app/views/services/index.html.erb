<% content_for :page_title, "Services" %>

<section class="table-container marketplace-page">
  <div class="table-header">
    <h1 class="table-title">Services</h1>
  </div>
  <div class="filter-bar">
    <%= form_with url: services_path, method: :get, local: true, class: "filter-grid compact" do |form| %>
      <div class="form-group" style="margin-bottom: 0;">
        <%= form.label :category, class: "form-label" %>
        <%= form.select :category, options_for_select(@categories, params[:category]), { include_blank: "All" }, { class: "form-select" } %>
      </div>
      <%= form.submit "Apply", class: "btn btn-primary" %>
    <% end %>
  </div>
  <nav class="category-strip" aria-label="Service categories">
    <%= link_to "All", services_path, class: "category-chip #{params[:category].blank? ? 'is-active' : ''}" %>
    <% @categories.each do |category| %>
      <%= link_to category, services_path(category: category), class: "category-chip #{params[:category] == category ? 'is-active' : ''}" %>
    <% end %>
  </nav>
  <% if @services.any? %>
    <div class="market-grid">
      <% @services.each do |service| %>
        <%= render "home/service_card", service: service, variant: :standard %>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state">
      <span class="empty-icon">🛠</span>
      <span>No services match your filters.</span>
    </div>
  <% end %>
  <%= pagination_controls(@services) %>
</section>
