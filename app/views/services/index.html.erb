<% content_for :page_title, "Services" %>
<% content_for :breadcrumbs do %>
  Marketplace / Services
<% end %>

<section class="page-section">
  <div class="section-header">
    <div>
      <h2 class="section-title">Marketplace Services</h2>
      <p class="section-subtitle">Find bookable services from marketplace providers.</p>
    </div>
  </div>

  <div class="filter-card">
    <%= form_with url: services_path, method: :get, local: true, class: "filter-grid", style: "grid-template-columns: 2fr 1fr auto;" do |form| %>
      <div class="form-group" style="margin-bottom: 0;">
        <%= form.label :q, "Search", class: "form-label" %>
        <%= form.text_field :q, value: params[:q], class: "form-input", placeholder: "Search services" %>
      </div>
      <div class="form-group" style="margin-bottom: 0;">
        <%= form.label :category, class: "form-label" %>
        <%= form.select :category, options_for_select(@categories, params[:category]), { include_blank: "All" }, { class: "form-select" } %>
      </div>
      <%= form.submit "Apply", class: "btn btn-primary" %>
    <% end %>
  </div>

  <% if @services.any? %>
    <div class="card-grid">
      <%= render partial: "shared/service_card", collection: @services, as: :service %>
    </div>
    <%= pagination_controls(@services) %>
  <% else %>
    <%= render "shared/empty_state",
               title: "No services found",
               message: "Try a different search or service category.",
               action: "View All Services",
               path: services_path %>
  <% end %>
</section>
