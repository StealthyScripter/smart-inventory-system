<% content_for :page_title, "Services" %>

<div class="table-container">
  <div class="table-header">
    <h3 class="table-title">Service Marketplace</h3>
  </div>
  <div class="filter-bar">
    <%= form_with url: services_path, method: :get, local: true, class: "filter-grid compact" do |form| %>
      <div class="form-group" style="margin-bottom: 0;">
        <%= form.label :category, class: "form-label" %>
        <%= form.select :category, options_for_select(@categories, params[:category]), { include_blank: "All" }, { class: "form-select" } %>
      </div>
      <%= form.submit "Apply", class: "btn btn-primary" %>
    <% end %>
  </div>
  <% if @services.any? %>
    <div class="market-grid">
      <% @services.each do |service| %>
        <article class="ui-card media-card">
          <div class="card-media">
            <% if safe_media_url?(service.image_url) %>
              <img src="<%= service.image_url %>" alt="<%= service.name %>">
            <% else %>
              <span><%= ui_initial(service.name) %></span>
            <% end %>
          </div>
          <div class="card-body">
            <h3 class="card-title clamp-2"><%= link_to service.name, service_path(service) %></h3>
            <div class="price">From <%= currency(service.starting_price.to_f) %></div>
            <div class="card-meta">
              <span class="meta-item">🛠 <%= service.service_category %></span>
              <span class="meta-item">★ <%= number_with_precision(service.average_rating, precision: 1) %></span>
            </div>
            <div class="card-meta">
              <span class="meta-item">🏬 <%= link_to service.supplier.name, merchant_storefront_path(service.supplier) %></span>
            </div>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state">
      <span class="empty-icon">🛠</span>
      <span>No services match your filters.</span>
    </div>
  <% end %>
  <%= pagination_controls(@services) %>
</div>
