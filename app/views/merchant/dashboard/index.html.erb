<% content_for :page_title, "Merchant Dashboard" %>
<% content_for :breadcrumbs do %>
  Merchant / Dashboard
<% end %>

<div style="margin-bottom: 1rem;">
  <span class="badge badge-info"><%= merchant_suppliers.map(&:name).to_sentence %></span>
</div>

<div class="stats-grid">
  <%= render "shared/metric_card", label: "Listings", value: number_with_delimiter(@product_count), hint: "Inventory products and marketplace-ready listings" %>
  <%= render "shared/metric_card", label: "Public Listings", value: number_with_delimiter(@public_product_count), hint: "Visible to customers" %>
  <%= render "shared/metric_card", label: "Draft / Private", value: number_with_delimiter(@non_public_product_count), hint: "Not public" %>
  <%= render "shared/metric_card", label: "Pending Orders", value: number_with_delimiter(@pending_orders_count), hint: "Need fulfillment attention" %>
  <%= render "shared/metric_card", label: "Services", value: number_with_delimiter(@service_count), hint: "Bookable provider offerings" %>
  <%= render "shared/metric_card", label: "Sales", value: currency(@sales_summary[:sales_total].to_f), hint: "Current sales summary" %>
</div>

<div class="grid-2">
  <div class="table-container">
    <div class="table-header">
      <h3 class="table-title">Low Stock</h3>
      <% if can_manage_merchant?(:view_inventory) %>
        <%= link_to "Local Inventory", merchant_inventory_path, class: "btn btn-secondary" %>
      <% end %>
    </div>
    <div style="padding: 1rem;">
      <% if @low_stock_products.any? %>
        <div class="card-grid compact">
          <% @low_stock_products.each do |product| %>
            <article class="ui-card">
              <div class="card-body">
                <div class="card-kicker">Local Inventory</div>
                <h3 class="card-title"><%= product.name %></h3>
                <div class="summary-row"><span>Stock</span><strong class="stock-low"><%= number_with_delimiter(product.total_stock) %></strong></div>
                <div class="summary-row"><span>Reorder Point</span><strong><%= product.reorder_point %></strong></div>
              </div>
            </article>
          <% end %>
        </div>
      <% else %>
        <%= render "shared/empty_state", title: "No low stock items" %>
      <% end %>
    </div>
  </div>

  <div class="table-container">
    <div class="table-header">
      <h3 class="table-title">Merchant Tools</h3>
    </div>
    <div style="padding: 1.5rem; display: flex; gap: 1rem; flex-wrap: wrap;">
      <% if can_manage_merchant?(:manage_catalog) %>
        <%= link_to "Marketplace Listings", merchant_products_path, class: "btn btn-primary" %>
      <% end %>
      <% if can_manage_merchant?(:manage_inventory) || can_manage_merchant?(:view_inventory) %>
        <%= link_to "Local Inventory", merchant_inventory_path, class: "btn btn-secondary" %>
      <% end %>
      <% if can_manage_merchant?(:view_orders) %>
        <%= link_to "Orders", merchant_orders_path, class: "btn btn-secondary" %>
      <% end %>
      <% if can_manage_merchant?(:manage_services) %>
        <%= link_to "Services", merchant_services_path, class: "btn btn-secondary" %>
      <% end %>
      <% if can_manage_merchant?(:manage_bookings) %>
        <%= link_to "Bookings", merchant_service_bookings_path, class: "btn btn-secondary" %>
      <% end %>
      <% if can_manage_merchant?(:manage_account_settings) %>
        <% merchant_suppliers.each do |supplier| %>
          <%= link_to "Shop: #{supplier.name}", edit_merchant_shop_path(supplier), class: "btn btn-secondary" %>
        <% end %>
        <% if current_merchant_account&.enterprise_merchant? %>
          <%= link_to "Settings", edit_merchant_account_settings_path, class: "btn btn-secondary" %>
        <% end %>
      <% end %>
      <% if can_manage_merchant?(:manage_members) && current_merchant_account&.enterprise_merchant? %>
        <%= link_to "Team", merchant_members_path, class: "btn btn-secondary" %>
      <% end %>
      <%= link_to "Analytics", merchant_analytics_path, class: "btn btn-secondary" %>
    </div>
  </div>
</div>

<div class="table-container">
  <div class="table-header">
    <h3 class="table-title">Recent Activity</h3>
  </div>
  <div style="padding: 1rem;">
    <% if @booking_queue.any? || @low_stock_products.any? %>
      <div class="card-grid compact">
        <% @booking_queue.each do |booking| %>
          <article class="ui-card">
            <div class="card-body">
              <div class="card-kicker">Booking Requested</div>
              <h3 class="card-title"><%= booking.booking_number %></h3>
              <p class="muted-text"><%= booking.created_at.to_fs(:short) %></p>
            </div>
          </article>
        <% end %>
        <% @low_stock_products.each do |product| %>
          <article class="ui-card">
            <div class="card-body">
              <div class="card-kicker">Low Stock</div>
              <h3 class="card-title"><%= product.name %></h3>
              <p><strong><%= number_with_delimiter(product.total_stock) %></strong> on hand</p>
            </div>
          </article>
        <% end %>
      </div>
    <% else %>
      <%= render "shared/empty_state", title: "No recent activity requiring attention" %>
    <% end %>
  </div>
</div>

<div class="grid-2">
  <div class="table-container">
    <div class="table-header">
      <h3 class="table-title">Booking Queue</h3>
      <%= link_to "Bookings", merchant_service_bookings_path, class: "btn btn-secondary" %>
    </div>
    <div style="padding: 1rem;">
      <% if @booking_queue.any? %>
        <div class="card-grid compact">
          <% @booking_queue.each do |booking| %>
            <article class="ui-card">
              <div class="card-body">
                <h3 class="card-title"><%= booking.booking_number %></h3>
                <p><%= booking.user.full_name %></p>
                <%= render "shared/status_badge", status: booking.status, label: booking.status.titleize %>
              </div>
            </article>
          <% end %>
        </div>
      <% else %>
        <%= render "shared/empty_state", title: "No bookings waiting for action" %>
      <% end %>
    </div>
  </div>

  <div class="table-container">
    <div class="table-header">
      <h3 class="table-title">Upcoming Jobs</h3>
    </div>
    <div style="padding: 1rem;">
      <% if @upcoming_jobs.any? %>
        <div class="card-grid compact">
          <% @upcoming_jobs.each do |booking| %>
            <article class="ui-card">
              <div class="card-body">
                <div class="card-kicker"><%= booking.scheduled_date %></div>
                <h3 class="card-title"><%= booking.service_listings.map(&:name).to_sentence %></h3>
                <%= render "shared/status_badge", status: booking.status, label: booking.status.titleize %>
              </div>
            </article>
          <% end %>
        </div>
      <% else %>
        <%= render "shared/empty_state", title: "No upcoming jobs scheduled" %>
      <% end %>
    </div>
  </div>
</div>
