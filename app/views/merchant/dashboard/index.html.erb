<% content_for :page_title, "Merchant Dashboard" %>
<% content_for :breadcrumbs do %>
  Merchant / Dashboard
<% end %>

<div class="action-row" style="margin-bottom: 1rem;">
  <span class="badge badge-info"><%= merchant_suppliers.map(&:name).to_sentence %></span>
</div>

<div class="stats-grid">
  <div class="stat-card">
    <div class="stat-header"><span class="stat-title">Listings</span></div>
    <div class="stat-value"><%= number_with_delimiter(@product_count) %></div>
  </div>

  <div class="stat-card">
    <div class="stat-header"><span class="stat-title">Public Listings</span></div>
    <div class="stat-value"><%= number_with_delimiter(@public_product_count) %></div>
  </div>

  <div class="stat-card">
    <div class="stat-header"><span class="stat-title">Draft / Private</span></div>
    <div class="stat-value"><%= number_with_delimiter(@non_public_product_count) %></div>
  </div>

  <div class="stat-card">
    <div class="stat-header"><span class="stat-title">Pending Orders</span></div>
    <div class="stat-value"><%= number_with_delimiter(@pending_orders_count) %></div>
  </div>

  <div class="stat-card">
    <div class="stat-header"><span class="stat-title">Services</span></div>
    <div class="stat-value"><%= number_with_delimiter(@service_count) %></div>
  </div>

  <div class="stat-card">
    <div class="stat-header"><span class="stat-title">Sales</span></div>
    <div class="stat-value"><%= currency(@sales_summary[:sales_total].to_f) %></div>
  </div>
</div>

<div class="grid-2">
  <div class="table-container">
    <div class="table-header">
      <h3 class="table-title">Low Stock</h3>
      <% if can_manage_merchant?(:view_inventory) %>
        <%= link_to "Local Inventory", merchant_inventory_path, class: "btn btn-secondary" %>
      <% end %>
    </div>
    <% if @low_stock_products.any? %>
      <div class="card-grid">
        <% @low_stock_products.each do |product| %>
          <article class="ui-card">
            <h3 class="card-title"><%= product.name %></h3>
            <div class="card-meta">
              <span class="stock-low">📦 <%= number_with_delimiter(product.total_stock) %></span>
              <span>Reorder <%= product.reorder_point %></span>
            </div>
          </article>
        <% end %>
      </div>
    <% else %>
      <div class="empty-state"><span class="empty-icon">✓</span><span>No low stock items.</span></div>
    <% end %>
  </div>

  <div class="table-container">
    <div class="table-header">
      <h3 class="table-title">Merchant Tools</h3>
    </div>
    <div class="card-grid">
      <% if can_manage_merchant?(:manage_catalog) %>
        <%= link_to "Marketplace Listings", merchant_products_path, class: "btn btn-primary" %>
      <% end %>
      <% if can_manage_merchant?(:manage_inventory) || can_manage_merchant?(:view_inventory) %>
        <%= link_to "Local Inventory", merchant_inventory_path, class: "btn btn-secondary" %>
      <% end %>
      <% if can_manage_merchant?(:view_orders) %>
        <%= link_to "Orders", merchant_orders_path, class: "btn btn-secondary" %>
      <% end %>
      <% if can_manage_merchant?(:manage_services) %>
        <%= link_to "Services", merchant_services_path, class: "btn btn-secondary" %>
      <% end %>
      <% if can_manage_merchant?(:manage_bookings) %>
        <%= link_to "Bookings", merchant_service_bookings_path, class: "btn btn-secondary" %>
      <% end %>
      <% if can_manage_merchant?(:manage_account_settings) %>
        <% merchant_suppliers.each do |supplier| %>
          <%= link_to "Shop: #{supplier.name}", edit_merchant_shop_path(supplier), class: "btn btn-secondary" %>
        <% end %>
        <% if current_merchant_account&.enterprise_merchant? %>
          <%= link_to "Settings", edit_merchant_account_settings_path, class: "btn btn-secondary" %>
        <% end %>
      <% end %>
      <% if can_manage_merchant?(:manage_members) && current_merchant_account&.enterprise_merchant? %>
        <%= link_to "Team", merchant_members_path, class: "btn btn-secondary" %>
      <% end %>
      <%= link_to "Analytics", merchant_analytics_path, class: "btn btn-secondary" %>
    </div>
  </div>
</div>

<div class="table-container">
  <div class="table-header">
    <h3 class="table-title">Recent Activity</h3>
  </div>
  <div class="card-grid">
      <% @booking_queue.each do |booking| %>
        <article class="ui-card">
          <span class="badge badge-info">Booking</span>
          <h3 class="card-title"><%= booking.booking_number %></h3>
          <div class="card-meta"><%= booking.created_at.to_fs(:short) %></div>
        </article>
      <% end %>
      <% @low_stock_products.each do |product| %>
        <article class="ui-card">
          <span class="badge badge-warning">Low Stock</span>
          <h3 class="card-title"><%= product.name %></h3>
          <div class="card-meta">📦 <%= number_with_delimiter(product.total_stock) %> on hand</div>
        </article>
      <% end %>
      <% if @booking_queue.empty? && @low_stock_products.empty? %>
        <div class="empty-state"><span class="empty-icon">✓</span><span>No recent activity requiring attention.</span></div>
      <% end %>
  </div>
</div>

<div class="grid-2">
  <div class="table-container">
    <div class="table-header">
      <h3 class="table-title">Booking Queue</h3>
      <%= link_to "Bookings", merchant_service_bookings_path, class: "btn btn-secondary" %>
    </div>
    <div class="card-grid">
        <% @booking_queue.each do |booking| %>
          <article class="ui-card">
            <h3 class="card-title"><%= booking.booking_number %></h3>
            <div class="card-meta">
              <span><%= booking.user.full_name %></span>
              <span class="badge <%= status_badge_class(booking.status) %>"><%= booking.status.titleize %></span>
            </div>
          </article>
        <% end %>
        <% if @booking_queue.empty? %>
          <div class="empty-state"><span class="empty-icon">✓</span><span>No bookings waiting for action.</span></div>
        <% end %>
    </div>
  </div>

  <div class="table-container">
    <div class="table-header">
      <h3 class="table-title">Upcoming Jobs</h3>
    </div>
    <div class="card-grid">
        <% @upcoming_jobs.each do |booking| %>
          <article class="ui-card">
            <h3 class="card-title"><%= booking.service_listings.map(&:name).to_sentence %></h3>
            <div class="card-meta">
              <span>📅 <%= booking.scheduled_date %></span>
              <span class="badge <%= status_badge_class(booking.status) %>"><%= booking.status.titleize %></span>
            </div>
          </article>
        <% end %>
        <% if @upcoming_jobs.empty? %>
          <div class="empty-state"><span class="empty-icon">📅</span><span>No upcoming jobs scheduled.</span></div>
        <% end %>
    </div>
  </div>
</div>
