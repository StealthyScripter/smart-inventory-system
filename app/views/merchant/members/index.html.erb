<% content_for :page_title, "Team" %>

<section class="page-section">
  <div class="section-header">
    <div>
      <h2 class="section-title">Team</h2>
      <p class="section-subtitle">Manage enterprise merchant access and roles.</p>
    </div>
  </div>

  <div class="summary-card">
    <%= form_with url: merchant_members_path, scope: :account_membership, local: true do |form| %>
      <div class="grid-2" style="gap: 1rem;">
        <div class="form-group">
          <%= form.label :email, "User email", class: "form-label" %>
          <%= form.email_field :email, class: "form-input", required: true %>
        </div>
        <div class="form-group" style="display: flex; align-items: end;">
          <%= form.submit "Add Member", class: "btn btn-primary" %>
        </div>
      </div>
    <% end %>
  </div>
</section>

<section class="page-section">
  <% if @memberships.any? %>
    <div class="card-grid">
      <% @memberships.each do |membership| %>
        <article class="ui-card">
          <div class="card-body">
            <div class="card-kicker"><%= membership.role.titleize %></div>
            <h3 class="card-title"><%= membership.user.full_name %></h3>
            <p class="card-meta"><%= membership.user.email %></p>
            <%= render "shared/status_badge", status: membership.active? ? "active" : "disabled", label: membership.active? ? "Active" : "Disabled" %>
          </div>
          <div class="card-actions">
            <%= form_with url: merchant_member_path(membership), method: :patch, scope: :account_membership, local: true, style: "display: flex; gap: 0.5rem; flex-wrap: wrap;" do |form| %>
              <%= form.select :role, AccountMembership::ROLES.map { |role| [role.titleize, role] }, { selected: membership.role }, class: "form-input" %>
              <%= form.submit "Update", class: "btn btn-secondary" %>
            <% end %>
            <% if membership.active? %>
              <%= button_to "Disable", merchant_member_path(membership), method: :delete, class: "btn btn-danger" %>
            <% else %>
              <%= button_to "Enable", enable_merchant_member_path(membership), method: :patch, class: "btn btn-secondary" %>
            <% end %>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <%= render "shared/empty_state", title: "No team members" %>
  <% end %>
</section>
