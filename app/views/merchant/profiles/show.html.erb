<% content_for :page_title, "Profile" %>

<% merchant_name = @merchant_profile&.display_name.presence || @account&.name || @primary_supplier&.name || merchant_suppliers.map(&:name).to_sentence %>
<% profile_edit_path = @can_manage_settings && @account.present? ? edit_merchant_account_settings_path : (@primary_supplier.present? ? edit_merchant_shop_path(@primary_supplier) : merchant_root_path) %>

<section class="customer-profile merchant-profile-hub" aria-labelledby="merchant-profile-name">
  <header class="customer-profile__header">
    <% if @primary_supplier&.logo&.attached? %>
      <%= image_tag @primary_supplier.logo, class: "customer-profile__avatar merchant-profile-hub__logo", alt: "#{merchant_name} logo" %>
    <% else %>
      <div class="customer-profile__avatar" role="img" aria-label="<%= merchant_name %> avatar">
        <span><%= merchant_name.split.filter_map { |word| word.first }.first(2).join.upcase %></span>
      </div>
    <% end %>
    <h1 id="merchant-profile-name" class="customer-profile__name"><%= merchant_name %></h1>
  </header>

  <nav class="customer-profile__primary-actions" aria-label="Merchant activity">
    <% if @can_view_orders %>
      <%= link_to merchant_orders_path, class: "customer-profile__primary-action" do %>
        <%= nav_icon(:orders) %>
        <span>Orders</span>
        <strong><%= @orders.size %></strong>
      <% end %>
    <% end %>

    <% if @can_manage_bookings %>
      <%= link_to merchant_service_bookings_path, class: "customer-profile__primary-action" do %>
        <%= nav_icon(:bookings) %>
        <span>Bookings</span>
        <strong><%= @bookings.size %></strong>
      <% end %>
    <% end %>
  </nav>

  <div class="customer-profile__list" role="list" aria-label="Merchant profile options">
    <% if @can_edit_profile || legacy_supplier_merchant? %>
      <%= link_to profile_edit_path, class: "customer-profile__row", role: "listitem" do %>
        <span class="customer-profile__row-icon"><%= nav_icon(:profile) %></span>
        <span class="customer-profile__row-label"><%= enterprise_merchant_navigation? ? "Edit company profile" : "Edit profile" %></span>
        <span class="customer-profile__chevron" aria-hidden="true">›</span>
      <% end %>
    <% end %>

    <% if @can_manage_catalog %>
      <%= link_to merchant_catalog_path, class: "customer-profile__row", role: "listitem" do %>
        <span class="customer-profile__row-icon"><%= nav_icon(:catalog) %></span>
        <span class="customer-profile__row-label">Catalog</span>
        <span class="customer-profile__chevron" aria-hidden="true">›</span>
      <% end %>

      <%= link_to merchant_products_path, class: "customer-profile__row", role: "listitem" do %>
        <span class="customer-profile__row-icon"><%= nav_icon(:products) %></span>
        <span class="customer-profile__row-label">Products</span>
        <span class="customer-profile__chevron" aria-hidden="true">›</span>
      <% end %>
    <% end %>

    <% if @can_view_inventory %>
      <%= link_to merchant_inventory_path, class: "customer-profile__row", role: "listitem" do %>
        <span class="customer-profile__row-icon"><%= nav_icon(:inventory) %></span>
        <span class="customer-profile__row-label">Inventory</span>
        <span class="customer-profile__chevron" aria-hidden="true">›</span>
      <% end %>
    <% end %>

    <% if @can_manage_team %>
      <%= link_to merchant_members_path, class: "customer-profile__row", role: "listitem" do %>
        <span class="customer-profile__row-icon"><%= nav_icon(:team) %></span>
        <span class="customer-profile__row-label">Team</span>
        <span class="customer-profile__chevron" aria-hidden="true">›</span>
      <% end %>
    <% end %>

    <% if @can_manage_locations %>
      <%= link_to locations_path, class: "customer-profile__row", role: "listitem" do %>
        <span class="customer-profile__row-icon"><%= nav_icon(:locations) %></span>
        <span class="customer-profile__row-label">Locations</span>
        <span class="customer-profile__chevron" aria-hidden="true">›</span>
      <% end %>
    <% end %>

    <% if @can_manage_settings %>
      <%= link_to edit_merchant_account_settings_path, class: "customer-profile__row", role: "listitem" do %>
        <span class="customer-profile__row-icon"><%= nav_icon(:settings) %></span>
        <span class="customer-profile__row-label">Access control</span>
        <span class="customer-profile__chevron" aria-hidden="true">›</span>
      <% end %>
    <% end %>

    <%= link_to merchant_conversations_path, class: "customer-profile__row", role: "listitem" do %>
      <span class="customer-profile__row-icon"><%= nav_icon(:inbox) %></span>
      <span class="customer-profile__row-label">Inbox</span>
      <span class="customer-profile__chevron" aria-hidden="true">›</span>
    <% end %>

    <%= link_to notifications_path, class: "customer-profile__row", role: "listitem" do %>
      <span class="customer-profile__row-icon"><%= nav_icon(:notifications) %></span>
      <span class="customer-profile__row-label">Notifications</span>
      <span class="customer-profile__row-meta"><%= @notifications_count %></span>
      <span class="customer-profile__chevron" aria-hidden="true">›</span>
    <% end %>

    <%= link_to merchant_analytics_path, class: "customer-profile__row", role: "listitem" do %>
      <span class="customer-profile__row-icon"><%= nav_icon(:analytics) %></span>
      <span class="customer-profile__row-label">Analytics</span>
      <span class="customer-profile__chevron" aria-hidden="true">›</span>
    <% end %>

    <% if @can_edit_profile || legacy_supplier_merchant? %>
      <%= link_to profile_edit_path, class: "customer-profile__row", role: "listitem" do %>
        <span class="customer-profile__row-icon"><%= nav_icon(:settings) %></span>
        <span class="customer-profile__row-label">Settings</span>
        <span class="customer-profile__chevron" aria-hidden="true">›</span>
      <% end %>
    <% end %>

    <div class="customer-profile__row is-disabled" role="listitem" aria-disabled="true">
      <span class="customer-profile__row-icon"><%= nav_icon(:help) %></span>
      <span class="customer-profile__row-label">Help</span>
    </div>

    <div class="customer-profile__row is-disabled" role="listitem" aria-disabled="true">
      <span class="customer-profile__row-icon"><%= nav_icon(:contact) %></span>
      <span class="customer-profile__row-label">Contact us</span>
    </div>

    <div class="customer-profile__signout" role="listitem">
      <%= button_to logout_path,
                    method: :delete,
                    form: { data: { turbo_confirm: "Are you sure you want to sign out?" } },
                    class: "customer-profile__row customer-profile__row--signout" do %>
        <span class="customer-profile__row-icon"><%= nav_icon(:signout) %></span>
        <span class="customer-profile__row-label">Sign out</span>
      <% end %>
    </div>
  </div>
</section>
