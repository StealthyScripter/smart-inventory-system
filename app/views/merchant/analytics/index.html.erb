<% content_for :page_title, "Merchant Analytics" %>

<div class="stats-grid">
  <div class="stat-card">
    <div class="stat-header"><span class="stat-title">Sales</span></div>
    <div class="stat-value"><%= currency(@sales_total.to_f) %></div>
  </div>
  <div class="stat-card">
    <div class="stat-header"><span class="stat-title">Delivered Items</span></div>
    <div class="stat-value"><%= number_with_delimiter(@delivered_count) %></div>
  </div>
  <div class="stat-card">
    <div class="stat-header"><span class="stat-title">Rating</span></div>
    <div class="stat-value"><%= number_with_precision(@average_rating, precision: 2) %></div>
  </div>
</div>
