<% content_for :page_title, "Service Bookings" %>

<div class="table-container">
  <div class="table-header"><h3 class="table-title">Booking Queue</h3></div>
  <div class="card-grid">
      <% @booking_queue.each do |booking| %>
        <%= render "shared/booking_card", booking: booking, show_customer: true %>
      <% end %>
      <% if @booking_queue.empty? %>
        <div class="empty-state"><span class="empty-icon">✓</span><span>No bookings waiting for action.</span></div>
      <% end %>
  </div>
</div>

<div class="table-container">
  <div class="table-header"><h3 class="table-title">Upcoming Jobs</h3></div>
  <div class="card-grid">
      <% @upcoming_jobs.each do |booking| %>
        <%= render "shared/booking_card", booking: booking, show_customer: true %>
      <% end %>
      <% if @upcoming_jobs.empty? %>
        <div class="empty-state"><span class="empty-icon">📅</span><span>No upcoming jobs scheduled.</span></div>
      <% end %>
  </div>
</div>

<div class="table-container">
  <div class="table-header"><h3 class="table-title">Calendar</h3></div>
  <div class="card-grid">
      <% @calendar_bookings.each do |date, bookings| %>
        <article class="ui-card booking-card booking-card--manage">
          <h3 class="card-title"><%= date %></h3>
          <div class="card-meta">📅 <%= bookings.map(&:booking_number).to_sentence %></div>
        </article>
      <% end %>
      <% if @calendar_bookings.empty? %>
        <div class="empty-state"><span class="empty-icon">📅</span><span>No bookings on the calendar.</span></div>
      <% end %>
  </div>
</div>

<div class="table-container">
  <div class="table-header"><h3 class="table-title">Service Bookings</h3></div>
  <% if @bookings.any? %>
    <div class="card-grid">
      <% @bookings.each do |booking| %>
        <article class="ui-card">
          <div class="card-meta">
            <span class="badge <%= status_badge_class(booking.status) %>"><%= booking.status.titleize %></span>
            <span>📅 <%= [booking.scheduled_date, booking.scheduled_time&.strftime("%H:%M")].compact.join(" ") %></span>
          </div>
          <h3 class="card-title"><%= booking.service_listings.map(&:service_category).uniq.to_sentence.presence || booking.booking_number %></h3>
          <div class="card-meta">
            <span><%= booking.user.full_name %></span>
            <span><%= booking.booking_number %></span>
          </div>
          <div class="card-actions">
            <%= link_to "Estimate PDF", estimate_merchant_service_booking_path(booking), class: "btn btn-secondary btn-compact" %>
          </div>
            <% next_statuses = ServiceBooking::TRANSITIONS.fetch(booking.status) %>
            <% if next_statuses.any? %>
              <%= form_with url: merchant_service_booking_path(booking), method: :patch, local: true, class: "stack" do |form| %>
                <%= form.select :status, options_for_select(next_statuses.map { |status| [status.titleize, status] }), {}, { class: "form-select" } %>
                <%= form.date_field :scheduled_date, value: booking.scheduled_date, class: "form-input" %>
                <%= form.time_field :scheduled_time, value: booking.scheduled_time&.strftime("%H:%M"), class: "form-input" %>
                <%= form.number_field :duration_minutes, value: booking.duration_minutes, min: 30, step: 30, class: "form-input" %>
                <%= form.submit "Update", class: "btn btn-secondary" %>
              <% end %>
            <% end %>
        </article>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state"><span class="empty-icon">📅</span><span>No service bookings yet.</span></div>
  <% end %>
</div>
