<% content_for :page_title, "Service Bookings" %>

<div class="table-container">
  <div class="table-header"><h3 class="table-title">Service Bookings</h3></div>
  <table>
    <thead>
      <tr><th>Booking</th><th>Customer</th><th>Service</th><th>Status</th><th>Schedule</th><th>Actions</th></tr>
    </thead>
    <tbody>
      <% @bookings.each do |booking| %>
        <tr>
          <td><%= booking.booking_number %></td>
          <td><%= booking.user.full_name %></td>
          <td><%= booking.service_listings.map(&:name).to_sentence %></td>
          <td><%= booking.status.titleize %></td>
          <td><%= [booking.scheduled_date, booking.scheduled_time&.strftime("%H:%M")].compact.join(" ") %></td>
          <td>
            <% next_statuses = ServiceBooking::TRANSITIONS.fetch(booking.status) %>
            <% if next_statuses.any? %>
              <%= form_with url: merchant_service_booking_path(booking), method: :patch, local: true do |form| %>
                <%= form.select :status, options_for_select(next_statuses.map { |status| [status.titleize, status] }), {}, { class: "form-select" } %>
                <%= form.date_field :scheduled_date, value: booking.scheduled_date, class: "form-input", style: "margin-top: 0.5rem;" %>
                <%= form.time_field :scheduled_time, value: booking.scheduled_time&.strftime("%H:%M"), class: "form-input", style: "margin-top: 0.5rem;" %>
                <%= form.number_field :duration_minutes, value: booking.duration_minutes, min: 30, step: 30, class: "form-input", style: "margin-top: 0.5rem;" %>
                <%= form.submit "Update", class: "btn btn-secondary", style: "margin-top: 0.5rem;" %>
              <% end %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
