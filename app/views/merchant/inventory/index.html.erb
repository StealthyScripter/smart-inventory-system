<% content_for :page_title, "Merchant Inventory" %>

<div class="table-container">
  <div class="table-header">
    <h3 class="table-title">Inventory</h3>
  </div>
  <div class="section-header">
    <h3 class="section-title">Location breakdown</h3>
  </div>
  <% if @stock_levels.any? %>
    <div class="card-grid">
      <% @stock_levels.each do |stock_level| %>
        <article class="ui-card">
          <h3 class="card-title"><%= stock_level.product.name %></h3>
          <div class="card-meta">
            <span>🏬 <%= stock_level.product.supplier&.name || "Marketplace" %></span>
            <span>📍 <%= stock_level.location.name %></span>
          </div>
          <div class="card-meta">
            <span>Current <strong><%= number_with_delimiter(stock_level.current_quantity) %></strong></span>
            <span>Reserved <%= number_with_delimiter(stock_level.reserved_quantity) %></span>
            <span>Available <strong><%= number_with_delimiter(stock_level.available_quantity) %></strong></span>
          </div>
          <%= form_with model: stock_level, url: merchant_inventory_item_path(stock_level), method: :patch, local: true, class: "inline-form" do |form| %>
              <%= form.number_field :current_quantity, min: 0, class: "form-input", style: "max-width: 7rem;" %>
              <%= form.submit "Save", class: "btn btn-secondary" %>
          <% end %>
        </article>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state"><span class="empty-icon">📦</span><span>No inventory found.</span></div>
  <% end %>
</div>

<div class="table-container">
  <div class="table-header">
    <h3 class="table-title">Marketplace visibility</h3>
  </div>
  <% if @inventory_products.any? %>
    <div class="card-grid">
      <% @inventory_products.each do |product| %>
        <article class="ui-card">
          <h3 class="card-title"><%= product.name %></h3>
          <div class="card-meta">
            <span><%= product.marketplace_status.titleize %></span>
            <span><%= product.listing_scope.titleize %></span>
          </div>
          <div class="card-actions">
            <%= button_to "List on marketplace", merchant_inventory_product_marketplace_path(product),
                          method: :patch,
                          params: { visibility_choice: "marketplace" },
                          class: "btn btn-primary" %>
            <%= button_to "Keep private/local", merchant_inventory_product_marketplace_path(product),
                          method: :patch,
                          params: { visibility_choice: "local" },
                          class: "btn btn-secondary" %>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state"><span class="empty-icon">📦</span><span>No inventory found.</span></div>
  <% end %>
</div>
