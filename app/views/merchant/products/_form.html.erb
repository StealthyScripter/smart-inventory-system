<div class="table-container">
  <div class="table-header">
    <h3 class="table-title"><%= submit_label %></h3>
    <%= link_to "Back to Products", merchant_products_path, class: "btn btn-secondary" %>
  </div>

  <div class="form-shell">
    <%= form_with model: [:merchant, product], local: true do |form| %>
      <% if product.errors.any? %>
        <div class="alert alert-danger">
          <strong><%= pluralize(product.errors.count, "error") %> prohibited this product from being saved:</strong>
          <ul style="margin-top: 0.5rem;">
            <% product.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="section-heading">
        <div>
          <span class="badge badge-secondary">Private / local</span>
          <h2 class="section-title">Inventory product</h2>
        </div>
      </div>

      <div class="grid-2 form-grid">
        <div>
          <div class="form-group">
            <%= form.label :name, class: "form-label" %>
            <%= form.text_field :name, class: "form-input", required: true %>
          </div>

          <div class="form-group">
            <%= form.label :sku, "SKU", class: "form-label" %>
            <%= form.text_field :sku, class: "form-input", required: true %>
          </div>

          <div class="form-group">
            <%= form.label :description, class: "form-label" %>
            <%= form.text_area :description, rows: 3, class: "form-input" %>
          </div>

          <div class="form-group">
            <%= form.label :category_id, "Category", class: "form-label" %>
            <%= form.select :category_id, options_from_collection_for_select(@categories, :id, :name, product.category_id),
                            { prompt: "Select a category..." }, { class: "form-select", required: true } %>
          </div>

          <div class="form-group">
            <%= form.label :supplier_id, "Supplier", class: "form-label" %>
            <%= form.select :supplier_id, options_from_collection_for_select(@suppliers, :id, :name, product.supplier_id),
                            {}, { class: "form-select" } %>
          </div>

          <div class="form-group">
            <%= form.label :marketplace_tag_list, "Backend marketplace tags", class: "form-label" %>
            <%= form.text_area :marketplace_tag_list, rows: 2, class: "form-input",
                               placeholder: "category:Construction essentials, event:Father's Day, action:Recommended" %>
            <div class="form-hint">Comma-separated context:name tags. Used for marketplace grouping; not shown on product cards.</div>
          </div>
        </div>

        <div>
          <div class="form-group">
            <%= form.label :listing_scope, "Inventory visibility", class: "form-label" %>
            <%= form.select :listing_scope,
                            options_for_select(Product::LISTING_SCOPES.map { |scope| [scope.titleize, scope] }, product.listing_scope),
                            {}, { class: "form-select" } %>
          </div>

          <div class="form-group">
            <%= form.label :unit_cost, "Unit Cost ($)", class: "form-label" %>
            <%= form.number_field :unit_cost, step: 0.01, min: 0, class: "form-input" %>
          </div>

          <div class="form-group">
            <%= form.label :selling_price, "Selling Price ($)", class: "form-label" %>
            <%= form.number_field :selling_price, step: 0.01, min: 0, class: "form-input" %>
          </div>

          <div class="form-group">
            <%= form.label :reorder_point, "Reorder Point", class: "form-label" %>
            <%= form.number_field :reorder_point, min: 1, class: "form-input", required: true %>
          </div>

          <div class="form-group">
            <%= form.label :lead_time_days, "Lead Time (Days)", class: "form-label" %>
            <%= form.number_field :lead_time_days, min: 1, class: "form-input", required: true %>
          </div>

          <div class="form-group">
            <%= form.label :featured_image, "Featured Image", class: "form-label" %>
            <%= form.file_field :featured_image, accept: "image/*", class: "form-input" %>
          </div>

          <div class="form-group">
            <%= form.label :images, "Product Images", class: "form-label" %>
            <%= form.file_field :images, multiple: true, accept: "image/*", class: "form-input" %>
          </div>
        </div>
      </div>

      <% listing = product.marketplace_listing || product.build_marketplace_listing(title: product.name, public_description: product.description, public_price: product.selling_price, status: "draft", visibility: "private", listing_type: "product", availability: "available") %>
      <div class="table-container form-section">
        <div class="table-header">
          <div>
            <span class="badge badge-info">Customer-facing</span>
            <h3 class="table-title">Marketplace listing</h3>
          </div>
        </div>
        <div class="form-section__body">
          <div class="grid-2 form-grid">
            <div>
              <div class="form-group">
                <%= label_tag "marketplace_listing_title", "Public Title", class: "form-label" %>
                <%= text_field_tag "marketplace_listing[title]", listing.title, class: "form-input" %>
              </div>

              <div class="form-group">
                <%= label_tag "marketplace_listing_public_description", "Public Description", class: "form-label" %>
                <%= text_area_tag "marketplace_listing[public_description]", listing.public_description, rows: 3, class: "form-input" %>
              </div>

              <div class="form-group">
                <%= label_tag "marketplace_listing_search_tags", "Public Search Tags", class: "form-label" %>
                <%= text_area_tag "marketplace_listing[search_tags]", listing.search_tags, rows: 2, class: "form-input" %>
              </div>
            </div>

            <div>
              <div class="form-group">
                <%= label_tag "marketplace_listing_public_price", "Public Price ($)", class: "form-label" %>
                <%= number_field_tag "marketplace_listing[public_price]", listing.public_price, step: 0.01, min: 0, class: "form-input" %>
              </div>

              <div class="form-group">
                <%= label_tag "marketplace_listing_sale_price", "Sale Price ($)", class: "form-label" %>
                <%= number_field_tag "marketplace_listing[sale_price]", listing.sale_price, step: 0.01, min: 0, class: "form-input" %>
              </div>

              <div class="form-group">
                <%= label_tag "marketplace_listing_availability", "Availability", class: "form-label" %>
                <%= select_tag "marketplace_listing[availability]",
                               options_for_select(MarketplaceListing::AVAILABILITIES.map { |value| [value.titleize, value] }, listing.availability),
                               class: "form-select" %>
              </div>

              <div class="form-group">
                <%= label_tag "marketplace_listing_status", "Listing Status", class: "form-label" %>
                <%= select_tag "marketplace_listing[status]",
                               options_for_select(MarketplaceListing::STATUSES.map { |status| [status.titleize, status] }, listing.status),
                               class: "form-select" %>
              </div>

              <div class="form-group">
                <%= label_tag "marketplace_listing_visibility", "Visibility", class: "form-label" %>
                <%= select_tag "marketplace_listing[visibility]",
                               options_for_select(MarketplaceListing::VISIBILITIES.map { |visibility| [visibility.titleize, visibility] }, listing.visibility),
                               class: "form-select" %>
              </div>

              <div class="form-group">
                <%= label_tag "marketplace_listing_featured_media_url", "Featured Media URL", class: "form-label" %>
                <%= text_field_tag "marketplace_listing[featured_media_url]", listing.featured_media_url, class: "form-input" %>
              </div>

              <div class="form-group">
                <%= label_tag "marketplace_listing_shipping_eligible", "Shipping Eligible", class: "form-label" %>
                <%= select_tag "marketplace_listing[shipping_eligible]",
                               options_for_select([["Yes", true], ["No", false]], listing.shipping_eligible),
                               class: "form-select" %>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="action-row form-actions">
        <%= form.submit submit_label, class: "btn btn-primary" %>
        <%= link_to "Cancel", merchant_products_path, class: "btn btn-secondary" %>
      </div>
    <% end %>
  </div>
</div>
