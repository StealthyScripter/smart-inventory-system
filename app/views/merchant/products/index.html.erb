<% content_for :page_title, "Merchant Products" %>

<div class="table-container">
  <div class="table-header">
    <h3 class="table-title">Products</h3>
    <%= link_to "Add Product", new_merchant_product_path, class: "btn btn-primary" %>
  </div>
  <table>
    <thead>
      <tr>
        <th>SKU</th>
        <th>Name</th>
        <th>Supplier</th>
        <th>Status</th>
        <th>Price</th>
        <th>Stock</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @products.each do |product| %>
        <tr>
          <td><%= product.sku %></td>
          <td><%= product.name %></td>
          <td><%= product.supplier&.name %></td>
          <td><span class="badge badge-secondary"><%= product.marketplace_status.titleize %></span></td>
          <td><%= currency(product.selling_price.to_f) %></td>
          <td><%= number_with_delimiter(product.total_stock) %></td>
          <td><%= link_to "Edit", edit_merchant_product_path(product), class: "btn btn-secondary", style: "padding: 0.25rem 0.5rem; font-size: 0.875rem;" %></td>
        </tr>
      <% end %>
      <% if @products.empty? %>
        <tr>
          <td colspan="7" style="text-align: center; color: #718096; font-style: italic;">No products found.</td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
