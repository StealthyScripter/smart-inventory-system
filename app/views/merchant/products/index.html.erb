<% content_for :page_title, "Merchant Products" %>

<div class="table-container">
  <div class="table-header">
    <h3 class="table-title">Products</h3>
    <div class="action-row">
      <%= link_to "Export CSV", merchant_products_export_path(format: :csv), class: "btn btn-secondary" %>
      <%= link_to "Add Product", new_merchant_product_path, class: "btn btn-primary" %>
    </div>
  </div>
  <div class="filter-bar">
    <%= form_with url: merchant_products_import_path, method: :post, local: true, multipart: true, class: "inline-form" do |form| %>
      <div class="form-group" style="margin-bottom: 0;">
        <%= form.label :file, "Import CSV", class: "form-label" %>
        <%= form.file_field :file, accept: ".csv,text/csv", class: "form-input" %>
      </div>
      <%= form.submit "Import", class: "btn btn-secondary" %>
    <% end %>
  </div>
  <%= form_with url: merchant_product_bulk_update_path, method: :post, local: true do |form| %>
    <div class="filter-bar">
      <div class="form-group" style="margin-bottom: 0;">
        <%= form.label :marketplace_status, "Status", class: "form-label" %>
        <%= form.select :marketplace_status, options_for_select(Product::MARKETPLACE_STATUSES.map { |status| [status.titleize, status] }), { include_blank: "No change" }, { class: "form-select" } %>
      </div>
      <div class="form-group" style="margin-bottom: 0;">
        <%= form.label :listing_scope, "Scope", class: "form-label" %>
        <%= form.select :listing_scope, options_for_select(Product::LISTING_SCOPES.map { |scope| [scope.titleize, scope] }), { include_blank: "No change" }, { class: "form-select" } %>
      </div>
      <%= form.submit "Apply to Selected", class: "btn btn-secondary" %>
    </div>
    <% if @products.any? %>
      <div class="card-grid product-management-grid">
        <% @products.each do |product| %>
          <article class="ui-card product-management-card">
            <div class="card-meta">
              <%= check_box_tag "product_ids[]", product.id, false, id: "product_ids_#{product.id}", aria: { label: "Select #{product.name}" } %>
              <span>SKU <strong><%= product.sku %></strong></span>
            </div>
            <h3 class="card-title"><%= product.name %></h3>
            <div class="card-meta">
              <%= render "shared/status_badge", status: product.marketplace_status, label: "Listing #{product.marketplace_status.titleize}" %>
              <%= render "shared/status_badge", status: product.listing_scope, label: product.listing_scope == "local" ? "Private / local stock" : "Marketplace" %>
            </div>
            <div class="card-meta">
              <span><%= product.supplier&.name %></span>
              <span><%= currency(product.selling_price.to_f) %></span>
              <span>Stock <strong><%= number_with_delimiter(product.total_stock) %></strong></span>
            </div>
            <div class="card-actions">
              <%= link_to "Edit", edit_merchant_product_path(product), class: "btn btn-secondary btn-compact" %>
              <%= button_to "Duplicate", merchant_product_duplicate_path(product), method: :post, class: "btn btn-secondary btn-compact" %>
            </div>
          </article>
        <% end %>
      </div>
    <% else %>
      <%= render "shared/empty_state", title: "No products", message: "Add a product to get started." %>
    <% end %>
  <% end %>
</div>
