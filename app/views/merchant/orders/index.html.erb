<% content_for :page_title, "Merchant Orders" %>

<div class="table-container">
  <div class="table-header">
    <h3 class="table-title">Incoming Orders</h3>
  </div>
  <table>
    <thead>
      <tr>
        <th>Order Number</th>
        <th>Supplier</th>
        <th>Status</th>
        <th>Order Date</th>
        <th>Items</th>
        <th>Total</th>
      </tr>
    </thead>
    <tbody>
      <% @order_items.each do |item| %>
        <tr>
          <td><%= item.order.order_number %></td>
          <td><%= item.supplier.name %></td>
          <td><span class="badge badge-secondary"><%= item.fulfillment_status.titleize %></span></td>
          <td><%= item.order.created_at.to_date %></td>
          <td><%= item.quantity %> x <%= item.product.name %></td>
          <td>
            <%= currency(item.total_amount.to_f) %>
            <% next_statuses = OrderItem::TRANSITIONS.fetch(item.fulfillment_status) %>
            <% if next_statuses.any? %>
              <%= form_with url: merchant_order_path(item), method: :patch, local: true, style: "margin-top: 0.5rem;" do |form| %>
                <%= form.select :fulfillment_status, options_for_select(next_statuses.map { |status| [status.titleize, status] }), {}, { class: "form-select" } %>
                <%= form.submit "Update", class: "btn btn-secondary", style: "margin-top: 0.5rem;" %>
              <% end %>
            <% end %>
          </td>
        </tr>
      <% end %>
      <% if @order_items.empty? %>
        <tr>
          <td colspan="6" style="text-align: center; color: #718096; font-style: italic;">No incoming orders found.</td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
