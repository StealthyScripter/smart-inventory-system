<% content_for :page_title, "Merchant Orders" %>

<div class="table-container">
  <div class="table-header">
    <h3 class="table-title">Incoming Orders</h3>
  </div>
  <% if @order_items.any? %>
    <div class="card-grid">
      <% @order_items.each do |item| %>
        <article class="ui-card">
          <div class="card-meta">
            <span class="badge <%= status_badge_class(item.fulfillment_status) %>"><%= item.fulfillment_status.titleize %></span>
            <span>📅 <%= item.order.created_at.to_date %></span>
          </div>
          <h3 class="card-title"><%= item.order.order_number %></h3>
          <div class="card-meta">
            <span>🏬 <%= item.supplier.name %></span>
            <span>📦 <%= item.quantity %> x <%= item.product.name %></span>
          </div>
          <div class="price"><%= currency(item.total_amount.to_f) %></div>
            <% next_statuses = OrderItem::TRANSITIONS.fetch(item.fulfillment_status) %>
            <% if next_statuses.any? %>
              <%= form_with url: merchant_order_path(item), method: :patch, local: true, class: "stack" do |form| %>
                <%= form.select :fulfillment_status, options_for_select(next_statuses.map { |status| [status.titleize, status] }), {}, { class: "form-select" } %>
                <%= form.text_field :tracking_carrier, value: item.tracking_carrier, placeholder: "Carrier", class: "form-input" %>
                <%= form.text_field :tracking_number, value: item.tracking_number, placeholder: "Tracking #", class: "form-input" %>
                <%= form.text_field :merchant_notes, value: item.merchant_notes, placeholder: "Notes", class: "form-input" %>
                <%= form.submit "Update", class: "btn btn-secondary" %>
              <% end %>
            <% end %>
        </article>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state"><span class="empty-icon">📦</span><span>No incoming orders found.</span></div>
  <% end %>
</div>
