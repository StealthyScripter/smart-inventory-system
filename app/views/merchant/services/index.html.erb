<% content_for :page_title, "Merchant Services" %>

<div class="table-container">
  <div class="table-header">
    <h3 class="table-title">Services</h3>
    <%= link_to "Add Service", new_merchant_service_path, class: "btn btn-primary" %>
  </div>
  <% if @services.any? %>
    <div class="card-grid">
      <% @services.each do |service| %>
        <article class="ui-card">
          <div class="card-meta">
            <span class="badge <%= status_badge_class(service.status) %>"><%= service.status.titleize %></span>
            <span class="badge badge-secondary"><%= service.visibility.titleize %></span>
          </div>
          <h3 class="card-title"><%= service.service_category %></h3>
          <% if service.name != service.service_category %><div class="card-meta clamp-2"><%= service.name %></div><% end %>
          <div class="price"><%= service.starting_price.present? ? "From #{currency(service.starting_price.to_f)}" : "Quote required" %></div>
          <div class="card-actions"><%= link_to "Edit", edit_merchant_service_path(service), class: "btn btn-secondary btn-compact" %></div>
        </article>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state"><span class="empty-icon">🛠</span><span>No services found.</span></div>
  <% end %>
</div>
