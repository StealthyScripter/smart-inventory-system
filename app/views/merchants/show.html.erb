<% content_for :page_title, @merchant.name %>

<div class="table-container">
  <div class="table-header">
    <h3 class="table-title"><%= @merchant.name %></h3>
    <%= link_to "Back to Catalog", catalog_path, class: "btn btn-secondary" %>
  </div>

  <div class="merchant-hero">
    <div class="hero-media">
      <% if @merchant.banner.attached? %>
        <%= image_tag @merchant.banner, alt: "#{@merchant.name} banner" %>
      <% elsif safe_media_url?(@merchant.shop_image_url) %>
        <img src="<%= @merchant.shop_image_url %>" alt="<%= @merchant.name %>">
      <% elsif @merchant.shop_image_url.present? %>
        <div class="hero-placeholder" data-image-url="<%= @merchant.shop_image_url %>"><%= ui_initial(@merchant.name) %></div>
      <% else %>
        <div class="hero-placeholder"><%= ui_initial(@merchant.name) %></div>
      <% end %>
    </div>
    <aside class="summary-panel stack">
      <% if @merchant.logo.attached? %>
        <%= image_tag @merchant.logo, alt: "#{@merchant.name} logo", style: "width: 72px; height: 72px; border-radius: var(--radius-lg); object-fit: cover;" %>
      <% end %>
      <p style="color: var(--muted-text);"><%= @merchant.shop_description.presence || "No shop description provided." %></p>
      <div class="card-meta">
        <span>★ <%= number_with_precision(@merchant.average_rating, precision: 2) %></span>
        <span>✉ <%= @merchant.contact_email.presence || "No email" %></span>
        <span>☎ <%= @merchant.contact_phone.presence || "No phone" %></span>
      </div>
    </aside>
  </div>

  <div class="section-header">
    <h3 class="section-title">Products</h3>
  </div>
  <% if @products.any? %>
    <div class="market-grid">
      <% @products.each do |product| %>
        <article class="ui-card media-card">
          <div class="card-media">
            <% if product.featured_image.attached? %>
              <%= image_tag product.featured_image, alt: product.name %>
            <% else %>
              <span><%= ui_initial(product.name) %></span>
            <% end %>
          </div>
          <div class="card-body">
            <h3 class="card-title clamp-2"><%= link_to product.name, catalog_product_path(product) %></h3>
            <div class="price"><%= currency(product.selling_price.to_f) %></div>
            <div class="card-meta">
              <span>🏷 <%= product.category.name %></span>
              <span>📦 <%= number_with_delimiter(product.available_stock) %></span>
            </div>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state"><span class="empty-icon">📦</span><span>This merchant has no public products.</span></div>
  <% end %>
</div>

<div class="table-container" style="margin-top: 1.5rem;">
  <div class="table-header">
    <h3 class="table-title">Services</h3>
  </div>
  <% if @services.any? %>
    <div class="market-grid">
      <% @services.each do |service| %>
        <article class="ui-card">
          <h3 class="card-title"><%= link_to service.name, service_path(service) %></h3>
          <div class="price">From <%= currency(service.starting_price.to_f) %></div>
          <div class="card-meta">🛠 <%= service.service_category %></div>
        </article>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state"><span class="empty-icon">🛠</span><span>No public services.</span></div>
  <% end %>
</div>
