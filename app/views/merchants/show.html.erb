<% content_for :page_title, @merchant.name %>

<section class="page-section">
  <article class="ui-card">
    <% if @merchant.banner.attached? %>
      <%= image_tag @merchant.banner, class: "merchant-banner", alt: "#{@merchant.name} banner" %>
    <% elsif @merchant.shop_image_url.present? %>
      <img class="merchant-banner" src="<%= @merchant.shop_image_url %>" alt="<%= @merchant.name %> storefront">
    <% else %>
      <div class="merchant-banner placeholder-media" role="img" aria-label="<%= @merchant.name %> storefront placeholder">
        <span><%= @merchant.name.to_s.first&.upcase || "M" %></span>
      </div>
    <% end %>

    <div class="card-body">
      <div class="section-header" style="margin-bottom: 0;">
        <div>
          <h2 class="section-title"><%= @merchant.name %></h2>
          <p class="section-subtitle"><%= @merchant.shop_description.presence || "Marketplace merchant storefront." %></p>
        </div>
        <div class="rating-row">
          <strong><%= number_with_precision(@merchant.average_rating, precision: 2) %> / 5</strong>
          <%= link_to "Back to Catalog", catalog_path, class: "btn btn-secondary" %>
        </div>
      </div>
      <div class="dashboard-card-grid">
        <div class="summary-card">
          <div class="card-kicker">Contact</div>
          <p><%= @merchant.contact_email.presence || "Email not provided" %></p>
          <p><%= @merchant.contact_phone.presence || "Phone not provided" %></p>
        </div>
        <div class="summary-card">
          <div class="card-kicker">Marketplace</div>
          <p><%= pluralize(@products.size, "public product") %></p>
          <p><%= pluralize(@services.size, "public service") %></p>
        </div>
      </div>
    </div>
  </article>
</section>

<section class="page-section">
  <div class="section-header">
    <h2 class="section-title">Products</h2>
  </div>
  <% product_listings = @products.filter_map(&:marketplace_listing) %>
  <% if product_listings.any? %>
    <div class="card-grid">
      <%= render partial: "shared/listing_card", collection: product_listings, as: :listing %>
    </div>
  <% else %>
    <%= render "shared/empty_state", title: "No public products", message: "This merchant has no public product listings." %>
  <% end %>
</section>

<section class="page-section">
  <div class="section-header">
    <h2 class="section-title">Services</h2>
  </div>
  <% if @services.any? %>
    <div class="card-grid">
      <%= render partial: "shared/service_card", collection: @services, as: :service %>
    </div>
  <% else %>
    <%= render "shared/empty_state", title: "No public services", message: "This merchant has no public services." %>
  <% end %>
</section>
