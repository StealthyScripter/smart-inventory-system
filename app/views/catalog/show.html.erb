<% content_for :page_title, @listing.title %>

<section class="table-container marketplace-detail">
  <div class="table-header">
    <h1 class="table-title"><%= @listing.title %></h1>
    <%= link_to "All products", catalog_path, class: "btn btn-secondary btn-compact" %>
  </div>

  <div class="product-hero">
    <div class="stack">
      <% if @product.featured_image.attached? %>
        <div class="hero-media"><%= image_tag @product.featured_image, alt: @product.name %></div>
      <% else %>
        <div class="hero-placeholder"><%= ui_initial(@listing.title) %></div>
      <% end %>
      <% if @product.images.attached? %>
        <div class="gallery-grid">
          <% @product.images.each do |image| %>
            <div class="card-media gallery-thumb"><%= image_tag image, alt: @listing.title %></div>
          <% end %>
        </div>
      <% end %>
    </div>

    <aside class="summary-panel stack">
      <div>
        <div class="price"><%= currency(@listing.current_price.to_f) %></div>
        <div class="card-meta">
          <span>🏷 <%= @product.category.name %></span>
          <span>★ <%= number_with_precision(@product.average_rating, precision: 1) %></span>
          <span class="badge <%= status_badge_class(@listing.availability) %>"><%= @listing.availability.titleize %></span>
        </div>
      </div>
      <div class="card-meta">🏬
          <% if @product.supplier %>
            <%= link_to @product.supplier.name, merchant_storefront_path(@product.supplier) %>
          <% else %>
            Marketplace
          <% end %>
      </div>
      <% if @listing.public_description.present? %>
        <p class="detail-description"><%= @listing.public_description %></p>
      <% end %>
      <%= form_with url: cart_path, method: :post, local: true, class: "stack" do |form| %>
        <%= form.hidden_field :product_id, value: @product.id %>
        <div class="form-group">
          <%= form.label :quantity, class: "form-label" %>
          <%= form.number_field :quantity, value: 1, min: 1, class: "form-input" %>
        </div>
        <div class="action-row">
          <%= form.submit "Add to cart", class: "btn btn-primary" %>
          <% if @product.supplier %>
            <%= link_to "View merchant", merchant_storefront_path(@product.supplier), class: "btn btn-secondary" %>
          <% end %>
        </div>
      <% end %>
    </aside>
  </div>
</section>

<section class="table-container detail-section">
  <div class="table-header">
    <h3 class="table-title">Reviews</h3>
  </div>
  <div class="card-grid">
    <% @product.reviews.published.includes(:user).each do |review| %>
      <article class="ui-card">
        <div class="card-meta"><strong>★ <%= review.rating %>/5</strong>
        <% if review.verified_purchase? %><span class="badge badge-success">Verified Purchase</span><% end %>
        </div>
        <%= review.body %>
      </article>
    <% end %>
    <% if @product.reviews.published.empty? %>
      <div class="empty-state"><span class="empty-icon">★</span><span>No reviews yet.</span></div>
    <% end %>
  </div>
</section>

<section class="table-container detail-section">
  <div class="table-header">
    <h3 class="table-title">Recommended Products</h3>
  </div>
  <div class="market-grid">
    <% @recommended_products.each do |product| %>
      <%= render "home/product_card", product: product, variant: :compact %>
    <% end %>
    <% if @recommended_products.empty? %>
      <div class="empty-state"><span class="empty-icon">⌕</span><span>No recommendations yet.</span></div>
    <% end %>
  </div>
</section>
