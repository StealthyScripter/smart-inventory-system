<% content_for :page_title, "Catalog" %>
<% content_for :breadcrumbs do %>
  Marketplace / Catalog
<% end %>

<div class="table-container">
  <div class="table-header">
    <h3 class="table-title">Marketplace Catalog</h3>
  </div>

  <div style="padding: 1rem 1.5rem; border-bottom: 1px solid #e2e8f0;">
    <%= form_with url: catalog_path, method: :get, local: true, style: "display: grid; grid-template-columns: 2fr 1fr 1fr 1fr auto; gap: 0.75rem; align-items: end;" do |form| %>
      <div class="form-group" style="margin-bottom: 0;">
        <%= form.label :q, "Search", class: "form-label" %>
        <%= form.text_field :q, value: params[:q], class: "form-input" %>
      </div>
      <div class="form-group" style="margin-bottom: 0;">
        <%= form.label :category_id, "Category", class: "form-label" %>
        <%= form.select :category_id, options_from_collection_for_select(@categories, :id, :name, params[:category_id]),
                        { include_blank: "All" }, { class: "form-select" } %>
      </div>
      <div class="form-group" style="margin-bottom: 0;">
        <%= form.label :supplier_id, "Merchant", class: "form-label" %>
        <%= form.select :supplier_id, options_from_collection_for_select(@suppliers, :id, :name, params[:supplier_id]),
                        { include_blank: "All" }, { class: "form-select" } %>
      </div>
      <div class="form-group" style="margin-bottom: 0;">
        <%= form.label :sort, "Sort", class: "form-label" %>
        <%= form.select :sort,
                        options_for_select([["Name", ""], ["Price: Low to High", "price_asc"], ["Price: High to Low", "price_desc"], ["Newest", "newest"]], params[:sort]),
                        {}, { class: "form-select" } %>
      </div>
      <%= form.submit "Apply", class: "btn btn-primary" %>
    <% end %>
  </div>

  <table>
    <thead>
      <tr>
        <th>Product</th>
        <th>Category</th>
        <th>Merchant</th>
        <th>Price</th>
        <th>Available</th>
      </tr>
    </thead>
    <tbody>
      <% @products.each do |product| %>
        <tr>
          <td><%= link_to product.name, catalog_product_path(product) %></td>
          <td><%= product.category.name %></td>
          <td>
            <% if product.supplier %>
              <%= link_to product.supplier.name, merchant_storefront_path(product.supplier) %>
            <% else %>
              Marketplace
            <% end %>
          </td>
          <td><%= currency(product.selling_price.to_f) %></td>
          <td><%= number_with_delimiter(product.available_stock) %></td>
        </tr>
      <% end %>

      <% if @products.empty? %>
        <tr>
          <td colspan="5" style="text-align: center; color: #718096; font-style: italic;">
            No public products are available.
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <%= pagination_controls(@products) %>
</div>
