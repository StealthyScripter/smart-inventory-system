<% content_for :page_title, "Catalog" %>
<% content_for :breadcrumbs do %>
  Marketplace / Catalog
<% end %>

<section class="page-section">
  <div class="section-header">
    <div>
      <h2 class="section-title">Marketplace Catalog</h2>
      <p class="section-subtitle">Browse public marketplace listings from verified merchants.</p>
    </div>
  </div>

  <div class="filter-card">
    <%= form_with url: catalog_path, method: :get, local: true, class: "filter-grid" do |form| %>
      <div class="form-group" style="margin-bottom: 0;">
        <%= form.label :q, "Search", class: "form-label" %>
        <%= form.text_field :q, value: params[:q], class: "form-input", placeholder: "Search products" %>
      </div>
      <div class="form-group" style="margin-bottom: 0;">
        <%= form.label :category_id, "Category", class: "form-label" %>
        <%= form.select :category_id, options_from_collection_for_select(@categories, :id, :name, params[:category_id]),
                        { include_blank: "All" }, { class: "form-select" } %>
      </div>
      <div class="form-group" style="margin-bottom: 0;">
        <%= form.label :supplier_id, "Merchant", class: "form-label" %>
        <%= form.select :supplier_id, options_from_collection_for_select(@suppliers, :id, :name, params[:supplier_id]),
                        { include_blank: "All" }, { class: "form-select" } %>
      </div>
      <div class="form-group" style="margin-bottom: 0;">
        <%= form.label :sort, "Sort", class: "form-label" %>
        <%= form.select :sort,
                        options_for_select([["Name", ""], ["Price: Low to High", "price_asc"], ["Price: High to Low", "price_desc"], ["Newest", "newest"]], params[:sort]),
                        {}, { class: "form-select" } %>
      </div>
      <%= form.submit "Apply", class: "btn btn-primary" %>
    <% end %>
  </div>

  <% if @product_listings.any? %>
    <div class="card-grid">
      <%= render partial: "shared/listing_card", collection: @product_listings, as: :listing %>
    </div>
    <%= pagination_controls(@product_listings) %>
  <% else %>
    <%= render "shared/empty_state",
               title: "No public products found",
               message: "Try a different search, category, merchant, or sort option.",
               action: "Clear Filters",
               path: catalog_path %>
  <% end %>
</section>
