<% content_for :page_title, "Dashboard" %>

<% if @low_stock_products.any? %>
  <div class="alert alert-warning">
    <strong>Low stock alert:</strong>
    <%= pluralize(@low_stock_products.count, "product") %> currently sits below its reorder point.
  </div>
<% end %>

<div class="stats-grid">
  <div class="stat-card">
    <div class="stat-header">
      <span class="stat-title">Products</span>
    </div>
    <div class="stat-value"><%= number_with_delimiter(@total_products) %></div>
  </div>

  <div class="stat-card">
    <div class="stat-header">
      <span class="stat-title">Locations</span>
    </div>
    <div class="stat-value"><%= number_with_delimiter(@total_locations) %></div>
  </div>

  <div class="stat-card">
    <div class="stat-header">
      <span class="stat-title">Inventory Units</span>
    </div>
    <div class="stat-value"><%= number_with_delimiter(@inventory_units) %></div>
  </div>

  <div class="stat-card">
    <div class="stat-header">
      <span class="stat-title">Inventory Value</span>
    </div>
    <div class="stat-value"><%= currency(@total_value) %></div>
  </div>
</div>

<div class="grid-2">
  <div class="table-container">
    <div class="table-header">
      <h3 class="table-title">Low Stock Products</h3>
      <%= link_to "View Inventory", inventory_path, class: "btn btn-secondary" %>
    </div>
    <table>
      <thead>
        <tr>
          <th>Product</th>
          <th>Stock</th>
          <th>Reorder Point</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        <% if @low_stock_products.any? %>
          <% @low_stock_products.each do |product| %>
            <% stock_quantity =
                 if current_user&.location_id && (location_manager? || department_manager? || employee?)
                   product.stock_levels.find { |level| level.location_id == current_user.location_id }&.current_quantity.to_i
                 else
                   product.total_stock
                 end %>
            <tr>
              <td><%= link_to product.name, product_path(product) %></td>
              <td class="stock-low"><%= number_with_delimiter(stock_quantity) %></td>
              <td><%= product.reorder_point %></td>
              <td>
                <% if stock_quantity.zero? %>
                  <span class="badge badge-danger">Out of Stock</span>
                <% else %>
                  <span class="badge badge-warning">Low Stock</span>
                <% end %>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="4" style="text-align: center; color: #718096; font-style: italic;">
              No low stock products right now.
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div class="table-container">
    <div class="table-header">
      <h3 class="table-title">Recent Inventory Movements</h3>
      <%= link_to "Inventory", inventory_path, class: "btn btn-primary" %>
    </div>
    <table>
      <thead>
        <tr>
          <th>Date</th>
          <th>Product</th>
          <th>Location</th>
          <th>Type</th>
          <th>Quantity</th>
        </tr>
      </thead>
      <tbody>
        <% if @recent_movements.any? %>
          <% @recent_movements.each do |movement| %>
            <tr>
              <td><%= movement.movement_date.strftime("%b %d, %H:%M") %></td>
              <td><%= movement.product.name %></td>
              <td><%= movement.destination_location&.name || movement.source_location&.name || "N/A" %></td>
              <td><%= movement.movement_type.titleize %></td>
              <td><%= movement.quantity %></td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="5" style="text-align: center; color: #718096; font-style: italic;">
              No inventory activity available for your scope.
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
