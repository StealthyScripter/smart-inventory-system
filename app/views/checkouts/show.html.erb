<% content_for :page_title, "Checkout" %>

<div class="table-container">
  <div class="table-header">
    <h3 class="table-title">Checkout</h3>
    <%= link_to "Back to Cart", cart_path, class: "btn btn-secondary" %>
  </div>
  <div class="card-grid">
    <% @cart.cart_items.includes(:product).each do |item| %>
      <article class="ui-card">
        <h3 class="card-title"><%= item.product.name %></h3>
        <div class="card-meta">
          <span>Qty <%= item.quantity %></span>
          <span><strong><%= currency(item.total_amount) %></strong></span>
        </div>
      </article>
    <% end %>
  </div>
  <div class="summary-panel action-row" style="margin: 0 1.25rem 1.25rem; justify-content: space-between;">
    <div class="price">Total <%= currency(@cart.total_amount) %></div>
    <%= button_to "Create Draft Order", checkout_path, method: :post, class: "btn btn-primary" %>
    <% if params[:order_id].present? %>
      <%= button_to "Start Manual Payment", payments_path(order_id: params[:order_id]), method: :post, class: "btn btn-secondary" %>
    <% end %>
  </div>
</div>
